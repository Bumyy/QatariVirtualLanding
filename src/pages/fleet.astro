const slugify = (value: string) => value
  .toLowerCase()
  .replace(/[^a-z0-9]+/g, '-')
  .replace(/(^-|-$)+/g, '');
---

<Layout title="Our Fleet" description="Explore the Qatari Virtual fleet, including Airbus and Boeing aircraft for passenger, cargo, and executive operations in Infinite Flight.">
<section class="px-6 py-8 min-h-screen">
  <div class="max-w-5xl mx-auto">
    <div class="flex justify-between items-start gap-4 mb-3">
      <h1 class="text-5xl font-bold text-[#8B1538]">Our Fleet</h1>
      <p class="text-sm text-gray-500 pt-2 hidden sm:inline">
        <a href="/" class="text-[#8B1538] font-semibold hover:underline">Home</a> / Fleet
      </p>
    </div>
    <p class="max-w-3xl text-lg text-gray-600 leading-relaxed mb-10">
      Our fleet comprises a range of narrow-body and wide-body Airbus and Boeing variants, operating short, medium, long-haul, and ultra-long-haul routes for both passengers and cargo.
    </p>

    {fleet.map((group) => (
      <div class="mb-12">
        <div class="flex flex-wrap items-center gap-3 mb-2">
          <h2 class="text-3xl font-bold text-[#8B1538]">{group.title}</h2>
          {group.badge && <span class="text-xs font-bold uppercase tracking-wider px-2.5 py-0.5 rounded-full text-white" style={`background: ${group.badgeColor}`}>{group.badge}</span>}
        </div>
        {group.desc && <p class="text-gray-500 text-sm mb-5 max-w-2xl">{group.desc}</p>}

        <div class="grid grid-cols-1 gap-5">
          {group.aircraft.map((ac) => (
            <div id={`fleet-${slugify(ac.name)}`} class="fleet-card reveal-card rounded-2xl border border-[#ead9df] bg-white shadow-sm hover:shadow-lg transition-shadow duration-300 overflow-hidden">
              <button class="fleet-toggle w-full text-left" data-fleet-toggle aria-expanded="false">
                <div class="flex flex-col md:flex-row">
                  <div class="fleet-img-stage w-full md:w-2/5 flex items-center justify-center p-6 md:p-8" style="background: linear-gradient(135deg, #4a0c2b, #6e0038)">
                    {ac.img ? (
                      <img src={ac.img} alt={`Qatari Virtual ${ac.name}`} class="fleet-img max-h-44 md:max-h-52 w-auto object-contain" loading="lazy" />
                    ) : (
                      <div class="text-white/20 text-5xl font-black tracking-wider select-none">{ac.name}</div>
                    )}
                  </div>
                  <div class="flex-1 p-5 md:p-7 flex flex-col justify-center">
                    <h3 class="text-2xl font-bold text-gray-800 mb-2">{ac.name}</h3>
                    <p class="text-gray-500 leading-relaxed text-sm mb-3">{ac.desc}</p>
                    <div class="flex flex-wrap items-center gap-2.5 text-xs mb-3">
                      <span class="bg-[#f8f1f3] text-[#8B1538] font-semibold px-3 py-1.5 rounded-full">Pax: {ac.pax}</span>
                      <span class="bg-[#f8f1f3] text-[#8B1538] font-semibold px-3 py-1.5 rounded-full">Range: {ac.range}</span>
                      <span class="bg-[#f8f1f3] text-[#8B1538] font-semibold px-3 py-1.5 rounded-full">{ac.speed}</span>
                    </div>
                    <a href={ac.rankUrl} class="inline-flex items-center gap-1.5 text-xs font-semibold hover:underline transition" style={`color: ${ac.rankColor}`}>
                      <span class="inline-block w-2 h-2 rounded-full flex-shrink-0" style={`background: ${ac.rankColor}`}></span>
                      Unlocks at {ac.rank} ({ac.rankRange})
                    </a>
                    <div class="flex items-center gap-1.5 mt-3 text-xs text-[#8B1538]/50 font-semibold">
                      <span>View specifications</span>
                      <svg class="fleet-chevron w-3.5 h-3.5 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="m6 9 6 6 6-6"/></svg>
                    </div>
                  </div>
                </div>
              </button>
              <div class="fleet-specs max-h-0 overflow-hidden transition-all duration-400">
                <div class="border-t border-[#ead9df] px-5 md:px-7 py-5 md:py-6 bg-[#fdfbfc]">
                  <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-2.5 text-sm">
                    <div class="flex justify-between py-1.5 border-b border-[#ead9df]/50"><span class="text-gray-400">Manufacturer</span><span class="font-medium text-gray-700">{ac.mfr}</span></div>
                    <div class="flex justify-between py-1.5 border-b border-[#ead9df]/50"><span class="text-gray-400">Role</span><span class="font-medium text-gray-700">{ac.role}</span></div>
                    <div class="flex justify-between py-1.5 border-b border-[#ead9df]/50"><span class="text-gray-400">Wingspan</span><span class="font-medium text-gray-700">{ac.wingspan}</span></div>
                    <div class="flex justify-between py-1.5 border-b border-[#ead9df]/50"><span class="text-gray-400">Category</span><span class="font-medium text-gray-700">{ac.cat}</span></div>
                    <div class="flex justify-between py-1.5 border-b border-[#ead9df]/50"><span class="text-gray-400">First Flight</span><span class="font-medium text-gray-700">{ac.firstFlight}</span></div>
                    <div class="flex justify-between py-1.5 border-b border-[#ead9df]/50"><span class="text-gray-400">MTOW</span><span class="font-medium text-gray-700">{ac.mtow}</span></div>
                    <div class="flex justify-between py-1.5 border-b border-[#ead9df]/50"><span class="text-gray-400">MLW</span><span class="font-medium text-gray-700">{ac.mlw}</span></div>
                    <div class="flex justify-between py-1.5 border-b border-[#ead9df]/50"><span class="text-gray-400">Ceiling</span><span class="font-medium text-gray-700">{ac.ceiling}</span></div>
                    <div class="flex justify-between py-1.5 border-b border-[#ead9df]/50"><span class="text-gray-400">MMO</span><span class="font-medium text-gray-700">{ac.mmo}</span></div>
                    <div class="flex justify-between py-1.5 border-b border-[#ead9df]/50 sm:col-span-2"><span class="text-gray-400">Engines</span><span class="font-medium text-gray-700">{ac.engines}</span></div>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    ))}

    <div class="text-center mt-10 mb-6">
      <a href="/ranks" class="text-sm text-[#8B1538] font-semibold hover:underline">View full rank structure to see when each aircraft unlocks &rarr;</a>
    </div>
  </div>
</section>

<style>
  .fleet-card { opacity: 0; transform: translateX(80px); transition: opacity 0.55s ease, transform 0.55s ease, box-shadow 0.3s ease; }
  .fleet-card.is-visible { opacity: 1; transform: translateX(0); }
  .fleet-card:hover { border-color: rgba(139, 21, 56, 0.25); }
  .fleet-img { filter: drop-shadow(0 10px 20px rgba(0,0,0,0.35)); opacity: 0; transform: translateX(60px); }
  .fleet-card.is-visible .fleet-img { animation: fleet-fly-in 0.7s ease forwards; }
  .fleet-card:hover .fleet-img { transform: translateX(0) scale(1.04); }
  @keyframes fleet-fly-in { from { opacity: 0; transform: translateX(60px); } to { opacity: 1; transform: translateX(0); } }
  .fleet-toggle[aria-expanded="true"] .fleet-chevron { transform: rotate(180deg); }
  .fleet-toggle[aria-expanded="true"] + .fleet-specs { max-height: 800px; }

  @media (max-width: 768px) {
    h1 { font-size: 2.5rem; }
    .fleet-card { transform: translateY(40px); }
    .fleet-card.is-visible { transform: translateY(0); }
    .fleet-img { max-height: 140px; }
    .fleet-img-stage { padding: 1.25rem; }
    .fleet-card h3 { font-size: 1.5rem; }
  }
  @media (prefers-reduced-motion: reduce) { .fleet-card, .fleet-card.is-visible { transition: none; transform: none; opacity: 1; } .fleet-img { animation: none; transform: none; opacity: 1; } }
</style>

<script>
  const cards = document.querySelectorAll('.fleet-card');

  function revealCard(card) {
    card.classList.add('is-visible');
  }

  const observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        setTimeout(function() { revealCard(entry.target); }, 30);
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.12 });

  cards.forEach(function(card) { observer.observe(card); });

  document.querySelectorAll('[data-fleet-toggle]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
    });
  });
</script>
</Layout>
