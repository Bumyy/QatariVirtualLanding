import Layout from '../layouts/Layout.astro';

interface Aircraft {
  name: string; img?: string; desc: string; pax: string; range: string; speed: string;
  ceiling: string; mfr: string; role: string; wingspan: string; cat: string;
  firstFlight: string; mtow: string; mlw: string; mmo: string; engines: string;
