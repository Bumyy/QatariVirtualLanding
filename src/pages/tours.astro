      LPPT: [38.7742, -9.1342],
      LXGB: [36.1512, -5.3497],
      VHHX: [22.3167, 114.2033],
      VILK: [26.7606, 80.8893],
      KJAC: [43.6073, -110.7377],
      KSLC: [40.7899, -111.9791],
      PADQ: [57.7499, -152.4939],
      LIPR: [44.0203, 12.6117],
      SPZO: [-13.5357, -71.9388],
      VTSM: [9.5483, 100.0614],
      FAPE: [-33.9849, 25.6173],
      OMDB: [25.2532, 55.3657],
      KSDF: [38.1744, -85.7360],
      KONT: [34.0560, -117.6012],
      MMMX: [19.4361, -99.0719],
      CYYC: [51.1139, -114.0203],
      OPKC: [24.9065, 67.1608],
      OPRN: [33.6167, 73.0992],
      RJAA: [35.7647, 140.3864],
      UBBB: [40.4675, 50.0467],
      UGTB: [41.6692, 44.9547],
      ELLX: [49.6266, 6.2115],
      KPHL: [39.8719, -75.2411],
      KROC: [43.1189, -77.6724],
      KAMA: [35.2194, -101.7059],
      KCHS: [32.8986, -80.0405],
      LEMH: [39.8626, 4.2186],
      VRMM: [4.1918, 73.5291],
      VRMG: [-0.6933, 73.1556],
      KMEM: [35.0424, -89.9767]
    };

    const tourCards = Array.from(document.querySelectorAll('[data-tour-card]'));
    const toggles = Array.from(document.querySelectorAll('[data-tour-toggle]'));
    const mapInstances = new Map();

    function closeAllTours(exceptId = null) {
      tourCards.forEach((card) => {
        const id = card.dataset.tourId;
        const toggle = card.querySelector('[data-tour-toggle]');
        if (id !== exceptId) {
          card.classList.remove('is-open');
          toggle?.setAttribute('aria-expanded', 'false');
        }
      });
    }

    function drawTourMap(mapEl) {
      const mapId = mapEl.id;
      if (mapInstances.has(mapId)) {
        setTimeout(() => mapInstances.get(mapId).invalidateSize(), 50);
        return;
      }

      const routeStrings = JSON.parse(mapEl.dataset.tourLegs || '[]');
      const parsedRoutes = routeStrings
        .map((r) => r.split('-').map((s) => s.trim()))
        .filter((parts) => parts.length === 2 && airportCoords[parts[0]] && airportCoords[parts[1]]);

      const map = L.map(mapEl, {
        zoomControl: false,
        worldCopyJump: false,
        attributionControl: false,
      }).setView([20, 20], 2);

      L.tileLayer(
        'https://tiles.stadiamaps.com/tiles/alidade_smooth/{z}/{x}/{y}{r}.png',
        {
          attribution: '&copy; OpenMapTiles &copy; OpenStreetMap contributors',
          noWrap: false,
        }
      ).addTo(map);

      const bounds = [];

      parsedRoutes.forEach(([from, to]) => {
        const A = airportCoords[from];
        const B = airportCoords[to];
        bounds.push(A, B);

        L.circleMarker(A, {
          radius: 5,
          fillColor: '#8B1538',
          color: '#ffffff',
          weight: 2,
          fillOpacity: 1,
        }).addTo(map);

        L.circleMarker(B, {
          radius: 5,
          fillColor: '#8B1538',
          color: '#ffffff',
          weight: 2,
          fillOpacity: 1,
        }).addTo(map);

        try {
          new L.Polyline.Arc(A, B, {
            color: '#8B1538',
            weight: 2,
            opacity: 0.8,
            vertices: 80,
          }).addTo(map);
        } catch {
          L.polyline([A, B], {
            color: '#8B1538',
            weight: 2,
            opacity: 0.8,
          }).addTo(map);
        }
      });

      if (bounds.length > 0) {
        map.fitBounds(bounds, { padding: [20, 20], maxZoom: 4 });
      }

      mapInstances.set(mapId, map);
      setTimeout(() => map.invalidateSize(), 50);
    }

    toggles.forEach((toggle) => {
      toggle.addEventListener('click', () => {
        const card = toggle.closest('[data-tour-card]');
        const id = card?.dataset.tourId;
        const isOpen = card?.classList.contains('is-open');

        if (!card || !id) return;

        if (isOpen) {
          card.classList.remove('is-open');
          toggle.setAttribute('aria-expanded', 'false');
          return;
        }

        closeAllTours(id);
        card.classList.add('is-open');
        toggle.setAttribute('aria-expanded', 'true');

        const mapEl = card.querySelector('[data-tour-map]');
        if (mapEl) {
          setTimeout(() => drawTourMap(mapEl), 220);
        }

        setTimeout(() => {
          card.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }, 120);
      });
    });

    const legCards = document.querySelectorAll('.leg-card');
    legCards.forEach((leg) => {
      const label = leg.querySelector('.leg-toggle-label');

      const syncLabel = () => {
        if (!label) return;
        label.textContent = leg.hasAttribute('open') ? 'Collapse' : 'Expand';
      };

      syncLabel();
      leg.addEventListener('toggle', syncLabel);
    });
  </script>
</Layout>