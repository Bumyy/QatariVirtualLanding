---

<Layout>
  <section class="px-6 py-8 min-h-screen">
    <div class="max-w-7xl mx-auto">
      <div class="mb-8">
        <div class="flex justify-between items-start gap-4 mb-3">
          <h1 class="text-5xl font-bold text-[#8B1538]">Tours</h1>
          <p class="text-sm text-gray-500 pt-2">
            <a href="/" class="text-[#8B1538] font-semibold hover:underline">Home</a> / Tours
          </p>
        </div>

        <p class="max-w-3xl text-lg text-gray-600 leading-relaxed">
          Explore curated journeys across the globe. Open a tour to view its route structure, overview, and eligible flights. All tours can be flown with a 2x multiplier.
        </p>
      </div>

      <div class="space-y-5" id="tourList">
        {tours.map((tour) => (
          <article
            class="tour-card rounded-3xl border border-[#ead9df] bg-white shadow-md overflow-hidden"
            data-tour-card
            data-tour-id={tour.id}
          >
            <button
              class="tour-summary w-full text-left"
              type="button"
              data-tour-toggle
              aria-expanded="false"
              aria-controls={`panel-${tour.id}`}
            >
              <div class="tour-summary-inner">
                <div class="tour-image-wrap">
                  <img src={tour.image} alt={tour.title} class="tour-image" />
                  <div class="tour-image-overlay"></div>
                </div>

                <div class="tour-copy">
                  <div class="flex flex-wrap items-center gap-3 mb-3">
                    <span class="tour-badge">{tour.status}</span>
                  </div>

                  <h2 class="text-3xl md:text-4xl font-bold text-white mb-2">{tour.title}</h2>
                  <p class="text-white/90 text-base md:text-lg max-w-2xl">
                    {tour.subtitle}
                  </p>
                </div>

                <div class="tour-action">
                  <span class="tour-action-label">View Tour</span>
                  <span class="tour-chevron">+</span>
                </div>
              </div>
            </button>

            <div id={`panel-${tour.id}`} class="tour-panel" data-tour-panel>
              <div class="tour-panel-inner">
                <div class="grid grid-cols-1 xl:grid-cols-[1.15fr_0.85fr] gap-8 mb-8 items-start">
                  <div>
                    <p class="text-base md:text-[1.05rem] text-gray-600 leading-7 max-w-4xl mb-6">
                      {tour.description}
                    </p>

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                      <div class="tour-stat">
                        <span class="tour-stat-label">Expiry Date</span>
                        <span class="tour-stat-value">{tour.expires}</span>
                      </div>
                      <div class="tour-stat">
                        <span class="tour-stat-label">Total Length</span>
                        <span class="tour-stat-value">{tour.totalNm}</span>
                      </div>
                      <div class="tour-stat">
                        <span class="tour-stat-label">Number of Legs</span>
                        <span class="tour-stat-value">{tour.legs.length}</span>
                      </div>
                      <div class="tour-stat">
                        <span class="tour-stat-label">Estimated Duration</span>
                        <span class="tour-stat-value">{tour.estimatedDuration}</span>
                      </div>
                    </div>
                  </div>

                  <div class="tour-map-card">
                    <div class="tour-map-head">
                      <h3 class="text-xl font-bold text-[#8B1538]">Tour Map</h3>
                    </div>
                    <div
                      class="tour-map"
                      id={`map-${tour.id}`}
                      data-tour-map
                      data-tour-legs={JSON.stringify(tour.legs.map((leg) => leg.route))}
                    ></div>
                  </div>
                </div>

                <div class="space-y-4">
                  {tour.legs.map((leg, index) => (
                    <details
                      class="leg-card rounded-2xl border border-[#ead9df] bg-[#fcfafb] overflow-hidden"
                      open={index === 0}
                    >
                      <summary class="leg-summary">
                        <div class="flex items-center justify-between gap-4">
                          <h3 class="text-2xl font-bold text-[#8B1538]">
                            {leg.leg}: {leg.route}
                          </h3>
                          <span class="leg-toggle-label text-[#8B1538] font-semibold">Expand</span>
                        </div>
                      </summary>

                      <div class="leg-content-wrap">
                        <div class="leg-content-inner px-6 pb-6 md:px-7 md:pb-7">
                          <p class="text-base md:text-[1.05rem] text-gray-600 leading-7 mb-6">
                            {leg.summary}
                          </p>

                          <h4 class="text-2xl font-bold text-[#8B1538] mb-3">Eligible routes</h4>
                          <p class="text-base md:text-[1.05rem] text-gray-600 leading-7 mb-6">
                            Choose one of the flight designations below to fly this leg.
                          </p>

                          <div class="overflow-x-auto">
                            <table class="w-full min-w-[760px] border-separate border-spacing-0">
                              <thead>
                                <tr>
                                  <th class="tour-th">Flight Number</th>
                                  <th class="tour-th">Departure Location</th>
                                  <th class="tour-th">Arrival Location</th>
                                  <th class="tour-th">Estimated Duration</th>
                                  <th class="tour-th">Aircraft</th>
                                </tr>
                              </thead>
                              <tbody>
                                {leg.eligibleRoutes.map((route) => (
                                  <tr>
                                    <td class="tour-td">{route.flight}</td>
                                    <td class="tour-td font-semibold text-gray-700">{route.depLoc}</td>
                                    <td class="tour-td font-semibold text-gray-700">{route.arrLoc}</td>
                                    <td class="tour-td">{route.duration}</td>
                                    <td class="tour-td">
                                      <div class="flex flex-wrap gap-2">
                                        {route.aircraft.split(',').map((ac) => (
                                          <span class="aircraft-pill">{ac.trim()}</span>
                                        ))}
                                      </div>
                                    </td>
                                  </tr>
                                ))}
                              </tbody>
                            </table>
                          </div>
                        </div>
                      </div>
                    </details>
                  ))}
                </div>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <link
    rel="stylesheet"
    href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
  />
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <script src="https://unpkg.com/leaflet-arc/bin/leaflet-arc.min.js"></script>

  <style>
    .tour-card {
      transition: box-shadow 0.35s ease, border-color 0.35s ease, transform 0.35s ease;
      box-shadow: 0 10px 30px rgba(139, 21, 56, 0.08);
    }

    .tour-card:hover {
      border-color: rgba(139, 21, 56, 0.22);
      box-shadow: 0 18px 40px rgba(139, 21, 56, 0.12);
    }

    .tour-summary {
      display: block;
      border: 0;
      background: transparent;
      padding: 0;
      cursor: pointer;
      width: 100%;
    }

    .tour-summary-inner {
      position: relative;
      min-height: 220px;
      display: grid;
      grid-template-columns: 1fr;
      align-items: stretch;
      overflow: hidden;
    }

    .tour-image-wrap {
      position: absolute;
      inset: 0;
    }

    .tour-image {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: transform 0.45s ease;
    }

    .tour-card:hover .tour-image {
      transform: scale(1.03);
    }

    .tour-image-overlay {
      position: absolute;
      inset: 0;
      background:
        linear-gradient(90deg, rgba(73, 4, 28, 0.82) 0%, rgba(73, 4, 28, 0.55) 40%, rgba(73, 4, 28, 0.35) 100%);
    }

    .tour-copy,
    .tour-action {
      position: relative;
      z-index: 2;
    }

    .tour-copy {
      padding: 2rem 2rem 1.5rem 2rem;
    }

    .tour-action {
      position: absolute;
      right: 1.5rem;
      top: 1.5rem;
      display: flex;
      align-items: center;
      gap: 0.9rem;
      color: white;
      font-weight: 700;
    }

    .tour-action-label {
      font-size: 0.95rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      opacity: 0.95;
    }

    .tour-chevron {
      width: 2.4rem;
      height: 2.4rem;
      border-radius: 999px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: rgba(255, 255, 255, 0.14);
      backdrop-filter: blur(8px);
      font-size: 1.4rem;
      line-height: 1;
      transition: transform 0.3s ease, background 0.3s ease;
    }

    .tour-badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 999px;
      padding: 0.45rem 0.9rem;
      background: rgba(255, 255, 255, 0.16);
      color: white;
      font-size: 0.8rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      backdrop-filter: blur(8px);
    }

    .tour-panel {
      display: grid;
      grid-template-rows: 0fr;
      transition: grid-template-rows 0.45s ease;
      background: white;
    }

    .tour-panel-inner {
      overflow: hidden;
      padding: 0 2rem;
    }

    .tour-card.is-open .tour-panel {
      grid-template-rows: 1fr;
    }

    .tour-card.is-open .tour-panel-inner {
      padding-top: 1.5rem;
      padding-bottom: 2rem;
    }

    .tour-card.is-open .tour-chevron {
      transform: rotate(45deg);
      background: rgba(255, 255, 255, 0.22);
    }

    .tour-stat {
      border: 1px solid rgba(139, 21, 56, 0.12);
      border-radius: 1rem;
      background: #fcfafb;
      padding: 1rem 1.1rem;
    }

    .tour-stat-label {
      display: block;
      font-size: 0.8rem;
      font-weight: 800;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(139, 21, 56, 0.72);
      margin-bottom: 0.35rem;
    }

    .tour-stat-value {
      display: block;
      font-size: 1.1rem;
      font-weight: 700;
      color: #4d4d56;
    }

    .tour-map-card {
      border: 1px solid rgba(139, 21, 56, 0.12);
      border-radius: 1.25rem;
      overflow: hidden;
      background: #fcfafb;
      box-shadow: 0 10px 22px rgba(139, 21, 56, 0.05);
    }

    .tour-map-head {
      padding: 1rem 1rem 0.75rem 1rem;
      border-bottom: 1px solid rgba(139, 21, 56, 0.1);
      background: white;
    }

    .tour-map {
      height: 280px;
      width: 100%;
    }

    .leg-card {
      box-shadow: 0 10px 22px rgba(139, 21, 56, 0.05);
    }

    .leg-summary {
      list-style: none;
      cursor: pointer;
      padding: 1.25rem 1.5rem;
    }

    .leg-summary::-webkit-details-marker {
      display: none;
    }

    .leg-content-wrap {
      display: grid;
      grid-template-rows: 0fr;
      transition: grid-template-rows 0.35s ease;
    }

    .leg-content-inner {
      overflow: hidden;
    }

    .leg-card[open] .leg-content-wrap {
      grid-template-rows: 1fr;
    }

    .tour-th {
      text-align: left;
      padding: 0 1rem 0.9rem 1rem;
      color: #8B1538;
      font-size: 1.1rem;
      font-weight: 800;
      border-bottom: 2px solid rgba(139, 21, 56, 0.45);
    }

    .tour-td {
      padding: 1rem;
      font-size: 1rem;
      color: #6b5f64;
      border-bottom: 2px solid rgba(139, 21, 56, 0.25);
    }

    .aircraft-pill {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0.35rem 0.7rem;
      border-radius: 0.6rem;
      background: #3a3a3f;
      color: white;
      font-weight: 700;
      font-size: 0.9rem;
      letter-spacing: 0.05em;
    }

    @media (max-width: 1024px) {
      .tour-map {
        height: 240px;
      }
    }

    @media (max-width: 768px) {
      .tour-copy {
        padding: 1.5rem 1.25rem 1.25rem 1.25rem;
      }

      .tour-action {
        right: 1rem;
        top: 1rem;
      }

      .tour-panel-inner {
        padding-left: 1rem;
        padding-right: 1rem;
      }

      .tour-card.is-open .tour-panel-inner {
        padding-bottom: 1.25rem;
      }

      .tour-th,
      .tour-td {
        font-size: 0.95rem;
      }

      .leg-summary h3 {
        font-size: 1.35rem;
      }

      .tour-map {
        height: 220px;
      }
    }
  </style>

  <script>
    const airportCoords = {
      OTHH: [25.2731, 51.6081],
      YSSY: [-33.9399, 151.1753],
      MPTO: [9.0714, -79.3835],
      SBBR: [-15.8692, -47.9208],
      SBGR: [-23.4356, -46.4731],
      SBRJ: [-22.9105, -43.1631],
      SCEL: [-33.3930, -70.7858],
      SCCI: [-53.0026, -70.8546],
      SCNT: [-51.6708, -72.5281],
      SPJC: [-12.0219, -77.1143],
      SACO: [-13.5357, -71.9388],
      SLLP: [-16.5133, -68.1923],
      HRYR: [-1.9600, 30.1400],
      HKJK: [-1.3200, 36.9200],
      FMMI: [-18.8000, 47.4800],
      FAOR: [-26.1337, 28.2420],
      FACT: [-33.9715, 18.6021],
      FAUP: [-28.4000, 21.2600],
      FASZ: [-24.9700, 31.5900],
      DNMM: [6.5800, 3.3200],
      GMMN: [33.3700, -7.5800],
      GMAD: [30.3300, -9.4100],
      DGAA: [5.6100, -0.1700],
      EDDK: [50.8659, 7.1427],
      EGLL: [51.4700, -0.4543],
      EFHK: [60.3172, 24.9633],
      EGPH: [55.9500, -3.3725],
      ESGG: [57.6628, 12.2798],
      LDDU: [42.5614, 18.2683],
      EGNM: [53.8659, -1.6606],
      LIRF: [41.8003, 12.2389],
      LBSF: [42.6952, 23.4061],
      LKPR: [50.1008, 14.2600],
      LFOB: [49.4600, 2.1128],
      LROP: [44.5711, 26.1971],
      LEMD: [40.4936, -3.5668],
      GOBD: [14.6710, -17.0733],
      LIRQ: [43.8100, 11.2051],
      LEBL: [41.2971, 2.0785],
      GEML: [35.2798, -2.9563],
      GCTS: [28.0445, -16.5725],
      KSFO: [37.6188, -122.3758],
      VVTS: [10.8188, 106.6519],
      WMKK: [2.7456, 101.7099],
      WBKW: [4.2625, 117.8872],
      WADD: [-8.7482, 115.1672],
      WAPP: [-3.7049, 128.0838],
      VVDN: [16.0439, 108.1993],
      ZBAD: [39.5091, 116.4105],
      RCTP: [25.0797, 121.2342],
      VIBY: [28.4208, 79.4503],
      YPPH: [-31.9403, 115.9668],
      ZYTX: [41.6397, 123.4833],
      VIDP: [28.5562, 77.1000],
      ZGGG: [23.3924, 113.2988],
      RKSI: [37.4602, 126.4407],
      RJTT: [35.5494, 139.7798],
      VHHH: [22.3080, 113.9185],
      WIII: [-6.1256, 106.6558],
      VABB: [19.0902, 72.8628],
      KJFK: [40.6413, -73.7781],
      KLAX: [33.9416, -118.4085],
      RJFT: [32.8372, 130.8550],
      WMKN: [5.3828, 103.1031],
      WAJJ: [-2.5764, 140.5161],
      RJSS: [38.1397, 140.9169],
      VVNB: [21.2211, 105.8072],
      RJCB: [42.7333, 143.2169],
      VLLB: [19.8986, 102.1625],
      ZLXY: [34.4472, 108.7517],
      VTSP: [8.1132, 98.3169],
      VTBS: [13.6811, 100.7472],
      VOKN: [11.9167, 75.5483],
    };

    const tourCards = Array.from(document.querySelectorAll('[data-tour-card]'));
    const toggles = Array.from(document.querySelectorAll('[data-tour-toggle]'));
    const mapInstances = new Map();

    function closeAllTours(exceptId = null) {
      tourCards.forEach((card) => {
        const id = card.dataset.tourId;
        const toggle = card.querySelector('[data-tour-toggle]');
        if (id !== exceptId) {
          card.classList.remove('is-open');
          toggle?.setAttribute('aria-expanded', 'false');
        }
      });
    }

    function drawTourMap(mapEl) {
      const mapId = mapEl.id;
      if (mapInstances.has(mapId)) {
        setTimeout(() => mapInstances.get(mapId).invalidateSize(), 50);
        return;
      }

      const routeStrings = JSON.parse(mapEl.dataset.tourLegs || '[]');
      const parsedRoutes = routeStrings
        .map((r) => r.split('-').map((s) => s.trim()))
        .filter((parts) => parts.length === 2 && airportCoords[parts[0]] && airportCoords[parts[1]]);

      const map = L.map(mapEl, {
        zoomControl: false,
        worldCopyJump: false,
        attributionControl: false,
      }).setView([20, 20], 2);

      L.tileLayer(
        'https://tiles.stadiamaps.com/tiles/alidade_smooth/{z}/{x}/{y}{r}.png',
        {
          attribution: '&copy; OpenMapTiles &copy; OpenStreetMap contributors',
          noWrap: false,
        }
      ).addTo(map);

      const bounds = [];

      parsedRoutes.forEach(([from, to]) => {
        const A = airportCoords[from];
        const B = airportCoords[to];
        bounds.push(A, B);

        L.circleMarker(A, {
          radius: 5,
          fillColor: '#8B1538',
          color: '#ffffff',
          weight: 2,
          fillOpacity: 1,
        }).addTo(map);

        L.circleMarker(B, {
          radius: 5,
          fillColor: '#8B1538',
          color: '#ffffff',
          weight: 2,
          fillOpacity: 1,
        }).addTo(map);

        try {
          new L.Polyline.Arc(A, B, {
            color: '#8B1538',
            weight: 2,
            opacity: 0.8,
            vertices: 80,
          }).addTo(map);
        } catch {
          L.polyline([A, B], {
            color: '#8B1538',
            weight: 2,
            opacity: 0.8,
          }).addTo(map);
        }
      });

      if (bounds.length > 0) {
        map.fitBounds(bounds, { padding: [20, 20], maxZoom: 4 });
      }

      mapInstances.set(mapId, map);
      setTimeout(() => map.invalidateSize(), 50);
    }

    toggles.forEach((toggle) => {
      toggle.addEventListener('click', () => {
        const card = toggle.closest('[data-tour-card]');
        const id = card?.dataset.tourId;
        const isOpen = card?.classList.contains('is-open');

        if (!card || !id) return;

        if (isOpen) {
          card.classList.remove('is-open');
          toggle.setAttribute('aria-expanded', 'false');
          return;
        }

        closeAllTours(id);
        card.classList.add('is-open');
        toggle.setAttribute('aria-expanded', 'true');

        const mapEl = card.querySelector('[data-tour-map]');
        if (mapEl) {
          setTimeout(() => drawTourMap(mapEl), 220);
        }

        setTimeout(() => {
          card.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }, 120);
      });
    });

    const legCards = document.querySelectorAll('.leg-card');
    legCards.forEach((leg) => {
      const label = leg.querySelector('.leg-toggle-label');

      const syncLabel = () => {
        if (!label) return;
        label.textContent = leg.hasAttribute('open') ? 'Collapse' : 'Expand';
      };

      syncLabel();
      leg.addEventListener('toggle', syncLabel);
    });
  </script>
</Layout>