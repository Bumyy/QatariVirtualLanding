---
import Layout from '../layouts/Layout.astro';
---

<Layout>

<section class="hero">
  <div class="overlay"></div>

  <div class="content">
    <p class="small-text">Welcome to Qatari Virtual</p>
    <h1 class="title">YOUR JOURNEY STARTS HERE</h1>
  </div>
</section>

<style>
  .hero {
    position: relative;
    width: 100%;
    height: 450px;
    background-image: url(https://global.discourse-cdn.com/infiniteflight/optimized/4X/8/d/6/8d64e734fbf27009765643e8d1d19329f4f4a54a_2_1230x858.jpeg);
    background-size: cover;
    background-position: center;
    border-bottom: 7px solid #6e0038;
    display: flex;
    justify-content: center;
    align-items: center;
    overflow: hidden;
  }
/* White tint */
  .overlay {
    position: absolute;
    inset: 0;
    background: rgba(255, 255, 255, 0.5); /* Adjust opacity here */
  }

  .content {
    position: relative;
    text-align: center;
    z-index: 2;
  }

  .small-text {
    color: #6e0038;
    font-size: 1.6rem;
    margin-bottom: 0.6rem;
    font-weight: 500;
  }

  .title {
    color: #6e0038;
    font-size: 4.0rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 2px;
  }
</style>

</Layout>