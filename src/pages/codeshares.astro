---
import Layout from '../layouts/Layout.astro';
import airlinesData from '../assets/airlines.json';
import { getRoutes } from '../data/route';
import csvText from '../assets/airports.csv?raw';

// Server-side helper to parse airports CSV
function parseCSV(csvText) {
  const airports = {};
  const lines = csvText.split('\n');

  for (let i = 1; i < lines.length; i++) {
    const line = lines[i];
    if (!line) continue;

    let parts = [];
    let current = "";
    let inQuotes = false;

    for (let c of line) {
      if (c === '"') {
        inQuotes = !inQuotes;
      } else if (c === ',' && !inQuotes) {
        parts.push(current);
        current = "";
      } else {
        current += c;
      }
    }
    parts.push(current);

    if (parts.length >= 8) {
      const icao = parts[1]?.trim();
      const name = parts[3]?.trim();
      const lat = parseFloat(parts[4]);
      const lng = parseFloat(parts[5]);
      const continent = parts[7]?.trim() || 'NA';

      if (icao && !isNaN(lat) && !isNaN(lng)) {
        airports[icao] = { name, icao, lat, lng, continent };
      }
    }
  }

  return airports;
}

const airportsMap = parseCSV(csvText);

// Filter out Qatar Airways carriers since this is specifically a codeshare partners page
const codeshares = airlinesData.airlines.filter(airline => airline.prefix !== 'QR');

let allRoutes = [];
try {
  allRoutes = await getRoutes();
} catch (error) {
  console.error('Failed to load routes for codeshares page:', error);
}

const owPrefixes = ['AA','AS','AY','BA','CX','IB','JL','MH','QF','AT','RJ','UL'];

// Process and map codeshare partners with stats, regions, and alliance flags
const codesharesWithStats = codeshares.map(airline => {
  let short = 0, medium = 0, long = 0, ultra = 0, total = 0;

  // Determine region from the first valid hub
  let region = 'OTHER';
  if (airline.hubs && airline.hubs.length > 0) {
    for (const hub of airline.hubs) {
      if (airportsMap[hub]) {
        region = airportsMap[hub].continent;
        break;
      }
    }
  }

  allRoutes.forEach(route => {
    const fltnum = route.fltnum || '';
    const match = airlinesData.airlines.find(a => a.suffix && fltnum.includes(a.suffix) && fltnum.startsWith(a.prefix))
               || airlinesData.airlines.find(a => !a.suffix && fltnum.startsWith(a.prefix));
    
    if (match && match.name === airline.name) {
      total++;
      const hours = (route.duration || 0) / 3600;
      if (hours < 3) short++;
      else if (hours < 6) medium++;
      else if (hours < 12) long++;
      else ultra++;
    }
  });

  const isOneWorld = owPrefixes.includes(airline.prefix);

  return { 
    ...airline, 
    region,
    isOneWorld,
    stats: { short, medium, long, ultra, total } 
  };
});
---

<Layout>
  <section class="px-6 py-8 min-h-screen">
    <div class="mb-8">
      <div class="flex justify-between items-start gap-4 mb-3">
        <h1 class="text-5xl font-bold text-[#8B1538]">Our Codeshares</h1>
        <p class="text-sm text-gray-500 pt-2 hidden sm:inline">
          <a href="/" class="text-[#8B1538] font-semibold hover:underline">Home</a> / Codeshares
        </p>
      </div>

      <p class="max-w-3xl text-lg text-gray-600 leading-relaxed">
        Explore Qatari Virtual’s growing network of codeshare partners across the world. Through these partnerships,
        our pilots can enjoy a wider range of destinations, routes, and operational experiences while representing the
        excellence and professionalism of Qatari Virtual.
      </p>
    </div>

    <!-- Filter Section (Region tabs & Search bar) -->
    <div class="mb-8 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
      <!-- Region Filter Tabs -->
      <div class="flex flex-wrap gap-2">
        <button class="region-tab active px-4 py-2 rounded-full text-xs font-bold border border-[#8B1538] bg-[#8B1538] text-white shadow-sm transition" data-region="ALL">
          All Regions
        </button>
        <button class="region-tab px-4 py-2 rounded-full text-xs font-bold border border-gray-200 bg-white text-gray-600 hover:border-[#8B1538] hover:text-[#8B1538] hover:bg-[#fdf8f9] transition" data-region="AS">
          Asia & Middle East
        </button>
        <button class="region-tab px-4 py-2 rounded-full text-xs font-bold border border-gray-200 bg-white text-gray-600 hover:border-[#8B1538] hover:text-[#8B1538] hover:bg-[#fdf8f9] transition" data-region="EU">
          Europe
        </button>
        <button class="region-tab px-4 py-2 rounded-full text-xs font-bold border border-gray-200 bg-white text-gray-600 hover:border-[#8B1538] hover:text-[#8B1538] hover:bg-[#fdf8f9] transition" data-region="NA">
          North America
        </button>
        <button class="region-tab px-4 py-2 rounded-full text-xs font-bold border border-gray-200 bg-white text-gray-600 hover:border-[#8B1538] hover:text-[#8B1538] hover:bg-[#fdf8f9] transition" data-region="SA">
          South America
        </button>
        <button class="region-tab px-4 py-2 rounded-full text-xs font-bold border border-gray-200 bg-white text-gray-600 hover:border-[#8B1538] hover:text-[#8B1538] hover:bg-[#fdf8f9] transition" data-region="AF">
          Africa
        </button>
        <button class="region-tab px-4 py-2 rounded-full text-xs font-bold border border-gray-200 bg-white text-gray-600 hover:border-[#8B1538] hover:text-[#8B1538] hover:bg-[#fdf8f9] transition" data-region="OC">
          Oceania
        </button>
      </div>

      <!-- Search Bar -->
      <div class="flex-shrink-0">
        <input
          id="searchInput"
          type="text"
          placeholder="Search airlines or codes..."
          class="border border-gray-300 px-4 py-2.5 rounded-full w-full sm:w-72 shadow-sm focus:outline-none focus:border-[#8B1538] focus:ring-1 focus:ring-[#8B1538] text-sm transition"
        />
      </div>
    </div>

    <!-- Grid List -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {codesharesWithStats.map((airline) => (
        <div 
          class="airline-card bg-white rounded-xl border border-[#e5d9dd] shadow-sm hover:shadow-lg hover:border-[#8B1538] transition duration-200 cursor-pointer overflow-hidden flex flex-col relative" 
          data-search={`${airline.name.toLowerCase()} ${airline.codeshare_code.toLowerCase()}`}
          data-region={airline.region}
          data-airline-id={airline.prefix}
        >
          {airline.isOneWorld && (
            <div class="absolute top-3 right-3 z-20 bg-blue-50 text-blue-700 border-blue-200 text-[10px] font-bold px-2.5 py-0.5 rounded-full border shadow-sm tracking-wide uppercase flex items-center gap-1.5">
              <span class="w-1.5 h-1.5 rounded-full bg-blue-500 animate-pulse"></span>
              oneworld
            </div>
          )}

          <div class="h-[180px] flex items-center justify-center p-6 bg-white relative z-10">
            {airline.logo ? (
              <img
                src={airline.logo}
                alt={airline.name}
                class="max-h-[85px] object-contain"
                loading="lazy"
              />
            ) : (
              <p class="text-gray-400 text-sm font-medium tracking-wide uppercase">
                Insert Image Here
              </p>
            )}
          </div>

          <div class="border-t border-[#e5d9dd] bg-[#faf7f8] px-4 py-3 flex justify-between items-center z-10 relative">
            <span class="text-[#8B1538] font-bold text-sm">
              {airline.name} ({airline.codeshare_code})
            </span>
            <div class="flex items-center gap-2">
              <a href={`/map?airline=${airline.prefix}`} class="text-xs text-gray-500 hover:text-[#8B1538] hover:underline flex items-center gap-1 font-semibold" title={`View ${airline.name} Route Map`}>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
                </svg>
                Map
              </a>
              <svg class="chevron w-5 h-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </div>
          </div>

          <div class="expanded-content bg-white">
            <div class="p-5 border-t border-[#e5d9dd]">
              <div class="mb-4">
                <span class="text-[10px] font-bold text-gray-400 uppercase tracking-wider block mb-1.5">Hubs</span>
                <div class="flex flex-wrap gap-1.5">
                  {airline.hubs?.map(hub => <span class="bg-[#f8f1f3] text-[#8B1538] text-[11px] font-bold px-2 py-0.5 rounded border border-[#ead9df]">{hub}</span>)}
                  {(!airline.hubs || airline.hubs.length === 0) && <span class="text-xs text-gray-500">N/A</span>}
                </div>
              </div>
              
              <div>
                <div class="flex items-center justify-between mb-2">
                  <span class="text-[10px] font-bold text-gray-400 uppercase tracking-wider">Routes Breakdown</span>
                  <span class="text-[10px] font-bold text-gray-500 bg-gray-100 px-2 py-0.5 rounded">{airline.stats.total} Total</span>
                </div>
                <div class="grid grid-cols-2 gap-2">
                  <div class="bg-[#fcfafb] border border-[#ead9df] p-2 rounded text-center">
                    <div class="text-[10px] text-gray-500 font-semibold mb-0.5">Short Haul</div>
                    <div class="text-sm font-bold text-[#8B1538]">{airline.stats.short}</div>
                  </div>
                  <div class="bg-[#fcfafb] border border-[#ead9df] p-2 rounded text-center">
                    <div class="text-[10px] text-gray-500 font-semibold mb-0.5">Medium Haul</div>
                    <div class="text-sm font-bold text-[#8B1538]">{airline.stats.medium}</div>
                  </div>
                  <div class="bg-[#fcfafb] border border-[#ead9df] p-2 rounded text-center">
                    <div class="text-[10px] text-gray-500 font-semibold mb-0.5">Long Haul</div>
                    <div class="text-sm font-bold text-[#8B1538]">{airline.stats.long}</div>
                  </div>
                  <div class="bg-[#fcfafb] border border-[#ead9df] p-2 rounded text-center">
                    <div class="text-[10px] text-gray-500 font-semibold mb-0.5">Ultra Long</div>
                    <div class="text-sm font-bold text-[#8B1538]">{airline.stats.ultra}</div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Disclaimer -->
    <div class="mt-12 p-6 rounded-2xl border border-[#ead9df] bg-[#fdf8f9] max-w-4xl mx-auto text-center z-10 relative">
      <p class="text-xs text-gray-500 leading-relaxed">
        <strong>Disclaimer:</strong> All airline logos, trademarks, and brand names featured on this page are the property of their respective owners. Qatari Virtual is a non-profit Virtual Airline community operating within the Infinite Flight flight simulator. The use of these logos is solely for educational, simulation, and entertainment purposes under fair use guidelines, and no copyright infringement, affiliation, endorsement, or ownership claim is intended.
      </p>
    </div>
  </section>

  <script>
    // Client-side Tab & Search Filtering
    const searchInput = document.getElementById('searchInput');
    const tabs = document.querySelectorAll('.region-tab');
    const cards = document.querySelectorAll('.airline-card');

    let currentRegion = 'ALL';
    let searchQuery = '';

    function filterAirlines() {
      cards.forEach(card => {
        const searchData = card.getAttribute('data-search') || '';
        const regionData = card.getAttribute('data-region') || '';

        const matchesSearch = searchData.includes(searchQuery);
        const matchesRegion = currentRegion === 'ALL' || regionData === currentRegion;

        if (matchesSearch && matchesRegion) {
          card.style.display = '';
        } else {
          card.style.display = 'none';
        }
      });
    }

    if (searchInput) {
      searchInput.addEventListener('input', (e) => {
        searchQuery = e.target.value.toLowerCase().trim();
        filterAirlines();
      });
    }

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        // Toggle tab styles
        tabs.forEach(t => {
          t.classList.remove('active', 'bg-[#8B1538]', 'text-white', 'border-[#8B1538]');
          t.classList.add('bg-white', 'text-gray-600', 'border-gray-200');
        });

        tab.classList.add('active', 'bg-[#8B1538]', 'text-white', 'border-[#8B1538]');
        tab.classList.remove('bg-white', 'text-gray-600', 'border-gray-200');

        currentRegion = tab.getAttribute('data-region') || 'ALL';
        filterAirlines();
      });
    });

    // Accordion Clicks
    cards.forEach(card => {
      card.addEventListener('click', (e) => {
        if (e.target.closest('a')) return;

        const isExpanding = !card.classList.contains('is-expanded');

        // Collapse all cards except this one
        cards.forEach(c => {
          if (c !== card) c.classList.remove('is-expanded');
        });

        card.classList.toggle('is-expanded', isExpanding);

        if (isExpanding) {
          setTimeout(() => {
            card.scrollIntoView({ behavior: 'smooth', block: 'center' });
          }, 200);
        }
      });
    });
  </script>

  <style>
    .expanded-content {
      max-height: 0;
      opacity: 0;
      overflow: hidden;
      transition: max-height 0.35s ease, opacity 0.25s ease;
    }
    .airline-card.is-expanded .expanded-content {
      max-height: 400px;
      opacity: 1;
      transition: max-height 0.4s ease, opacity 0.3s ease 0.1s;
    }
    .chevron {
      transition: transform 0.3s ease;
    }
    .airline-card.is-expanded .chevron {
      transform: rotate(180deg);
    }
  </style>
</Layout>