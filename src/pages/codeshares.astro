<Layout>

<section class="px-6 py-6 bg-[#efe9e9] min-h-screen">

  <!-- Header -->
  <div class="flex justify-between items-start mb-6">
    <h1 class="text-5xl font-light text-gray-800">Our Airlines</h1>
    <p class="text-sm text-gray-500">
      <a href="/" class="text-[#8B1538] font-semibold hover:underline">Home</a> / Airlines
    </p>
  </div>

  <!-- Grid -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">

    <!-- Card -->
    <div class="bg-white rounded-lg border border-[#d9cfd2] shadow-sm hover:shadow-lg hover:border-[#8B1538] transition">
      <div class="h-[250px] flex items-center justify-center p-6">
        <img src="https://logo.clearbit.com/aerlingus.com" class="max-h-[120px] object-contain" />
      </div>
      <div class="border-t bg-[#f7f2f3] px-4 py-3">
        <a href="#" class="text-[#8B1538] font-semibold text-sm hover:underline">
          Aer Lingus (EIN/EI)
        </a>
      </div>
    </div>

    <!-- Repeat cards -->
    <div class="bg-white rounded-lg border border-[#d9cfd2] shadow-sm hover:shadow-lg hover:border-[#8B1538] transition">
      <div class="h-[250px] flex items-center justify-center p-6">
        <img src="https://logo.clearbit.com/aa.com" class="max-h-[120px] object-contain" />
      </div>
      <div class="border-t bg-[#f7f2f3] px-4 py-3">
        <a href="#" class="text-[#8B1538] font-semibold text-sm hover:underline">
          American Airlines (AAL/AA)
        </a>
      </div>
    </div>

    <div class="bg-white rounded-lg border border-[#d9cfd2] shadow-sm hover:shadow-lg hover:border-[#8B1538] transition">
      <div class="h-[250px] flex items-center justify-center p-6">
        <img src="https://logo.clearbit.com/britishairways.com" class="max-h-[120px] object-contain" />
      </div>
      <div class="border-t bg-[#f7f2f3] px-4 py-3">
        <a href="#" class="text-[#8B1538] font-semibold text-sm hover:underline">
          British Airways (BAW/BA)
        </a>
      </div>
    </div>

    <div class="bg-white rounded-lg border border-[#d9cfd2] shadow-sm hover:shadow-lg hover:border-[#8B1538] transition">
      <div class="h-[250px] flex items-center justify-center p-6">
        <img src="https://logo.clearbit.com/cathaypacific.com" class="max-h-[120px] object-contain" />
      </div>
      <div class="border-t bg-[#f7f2f3] px-4 py-3">
        <a href="#" class="text-[#8B1538] font-semibold text-sm hover:underline">
          Cathay Pacific (CPA/CX)
        </a>
      </div>
    </div>

  </div>

</section>

</Layout>