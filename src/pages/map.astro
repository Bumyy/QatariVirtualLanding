---
import Layout from '../layouts/Layout.astro';
import { getRoutes } from '../data/route';
import airlinesData from '../assets/airlines.json';
import csvText from '../assets/airports.csv?raw';

const airlines = airlinesData.airlines;
let allRoutes = [];

try {
  allRoutes = await getRoutes();
} catch (error) {
  console.error('Failed to load routes:', error);
  allRoutes = [];
}
---

<Layout>
  <section class="px-6 py-8 min-h-screen">
    <div class="mb-8">
      <div class="flex justify-between items-start gap-4 mb-3">
        <h1 class="text-5xl font-bold text-[#8B1538]">Interactive Route Map</h1>
        <p class="text-sm text-gray-500 pt-2 hidden sm:inline">
          <a href="/" class="text-[#8B1538] font-semibold hover:underline">Home</a> / Route Map
        </p>
      </div>

      <p class="max-w-3xl text-lg text-gray-600 leading-relaxed">
        Explore our global network and discover where Qatari Virtual flies with our interactive route map.
      </p>
    </div>

    <div class="flex flex-wrap justify-center items-center gap-4 mt-4">
      <select
        id="airlineSelect"
        class="border border-gray-300 px-4 py-2 rounded shadow-sm"
      >
        <option value="">Select Airline...</option>
        {airlines.map((airline) => (
          <>
            <option value={airline.suffix ? `${airline.prefix}_${airline.suffix}` : airline.prefix} data-color={airline.color}>
              {airline.name}
            </option>
            {(airline.name === 'Qatar Airways' && !airline.suffix) && (
              <option value="ALL" data-color="#8B1538">All Routes</option>
            )}
          </>
        ))}
      </select>

      <select
        id="regionSelect"
        class="border border-gray-300 px-4 py-2 rounded shadow-sm"
      >
        <option value="ALL">All Regions</option>
        <option value="AF">Africa</option>
        <option value="AS">Asia & Middle East</option>
        <option value="EU">Europe</option>
        <option value="NA">North America</option>
        <option value="OC">Oceania</option>
        <option value="SA">South America</option>
      </select>

      <input
        id="airportSearch"
        type="text"
        placeholder="Search airport..."
        class="border border-gray-300 px-4 py-2 rounded w-60 shadow-sm"
      />

      <label class="flex items-center gap-2 cursor-pointer text-gray-700 font-medium">
        <input
          type="checkbox"
          id="showLinesToggle"
          class="w-4 h-4 accent-[#8B1538] cursor-pointer"
        />
        Show Lines
      </label>
    </div>

    <div id="routeInfo" class="text-center mt-2 text-sm text-gray-600"></div>

    <style>
      #map {
        height: 70vh;
        width: 100%;
        margin-top: 1rem;
      }

      .leaflet-popup-content {
        font-size: 14px;
      }

      .leaflet-popup-content strong {
        font-weight: bold;
      }
    </style>

    <div id="map"></div>

    <link
      rel="stylesheet"
      href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
    />
    <script
      src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
      client:load
    ></script>
    <script
      src="https://unpkg.com/leaflet-arc/bin/leaflet-arc.min.js"
      client:load
    ></script>

    <script client:load define:vars={{ allRoutes, csvText, airlines }}>
      const map = L.map("map", {
        worldCopyJump: false,
      }).setView([20, 10], 2);

      L.tileLayer(
        "https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png",
        {
          attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors &copy; <a href="https://carto.com/">CARTO</a>',
          noWrap: false,
        }
      ).addTo(map);

      let currentColor = "#ff0000";
      let airportData = {};
      let currentRoutes = [];
      let connections = {};
      let markers = {};
      let drawn = [];
      let currentPrefix = "";
      let currentFltnum = "";
      let currentRegion = "ALL";

      const airlineSelect = document.getElementById("airlineSelect");
      const regionSelect = document.getElementById("regionSelect");
      const showLinesToggle = document.getElementById("showLinesToggle");
      const routeInfo = document.getElementById("routeInfo");
      const searchInput = document.getElementById("airportSearch");

      function parseCSV(csvText) {
        const airports = {};
        const lines = csvText.split("\n");

        for (let i = 1; i < lines.length; i++) {
          const line = lines[i];
          if (!line) continue;

          let parts = [];
          let current = "";
          let inQuotes = false;

          for (let c of line) {
            if (c === '"') {
              inQuotes = !inQuotes;
            } else if (c === "," && !inQuotes) {
              parts.push(current);
              current = "";
            } else {
              current += c;
            }
          }
          parts.push(current);

          if (parts.length >= 8) {
            const icao = parts[1]?.trim();
            const name = parts[3]?.trim();
            const lat = parseFloat(parts[4]);
            const lng = parseFloat(parts[5]);
            const continent = parts[7]?.trim() || "NA";

            if (icao && !isNaN(lat) && !isNaN(lng)) {
              airports[icao] = { name, icao, lat, lng, continent };
            }
          }
        }

        return airports;
      }

      function clearRoutes() {
        drawn.forEach((layer) => map.removeLayer(layer));
        drawn = [];
      }

      function clearMarkers() {
        Object.values(markers).forEach((group) => {
          group.forEach((marker) => map.removeLayer(marker));
        });
        markers = {};
      }

      function interpolateLat(lat1, lon1, lat2, lon2, targetLon) {
        const t = (targetLon - lon1) / (lon2 - lon1);
        return lat1 + (lat2 - lat1) * t;
      }

      function makePopupHtml(route) {
        if (!route) return "";
        const aircraftList =
          route.aircraft.length > 0
            ? "<ul>" +
              route.aircraft
                .map((a) => `<li>${a.liveryname} ${a.name}</li>`)
                .join("") +
              "</ul>"
            : "No aircraft assigned";

        return `<strong>${route.fltnum}</strong><br>${route.dep} → ${route.arr}<br><strong>Aircraft:</strong><br>${aircraftList}`;
      }

      function makeBezierSegment(start, control, end, routeColor, weight, opacity, popupHtml) {
        const [lat1, lon1] = start;
        const [cLat, cLon] = control;
        const [lat2, lon2] = end;

        const points = [];
        const steps = 60;

        for (let i = 0; i <= steps; i++) {
          const t = i / steps;
          const oneMinusT = 1 - t;

          const lat =
            oneMinusT * oneMinusT * lat1 +
            2 * oneMinusT * t * cLat +
            t * t * lat2;

          const lon =
            oneMinusT * oneMinusT * lon1 +
            2 * oneMinusT * t * cLon +
            t * t * lon2;

          points.push([lat, lon]);
        }

        const layer = L.polyline(points, {
          color: routeColor,
          weight,
          opacity,
          smoothFactor: 1,
          lineCap: "round",
          lineJoin: "round",
        });

        if (popupHtml) layer.bindPopup(popupHtml);
        layer.addTo(map);
        drawn.push(layer);
      }

      function makeNormalArc(start, end, routeColor, weight, opacity, popupHtml) {
        let layer;
        try {
          layer = new L.Polyline.Arc(start, end, {
            color: routeColor,
            weight,
            opacity,
            vertices: 120,
          });
        } catch {
          layer = L.polyline([start, end], {
            color: routeColor,
            weight,
            opacity,
          });
        }

        if (popupHtml) layer.bindPopup(popupHtml);
        layer.addTo(map);
        drawn.push(layer);
      }

      function drawArc(fromCode, toCode) {
        const A = airportData[fromCode];
        const B = airportData[toCode];
        if (!A || !B) return;

        const route = currentRoutes.find(
          (r) =>
            (r.dep === fromCode && r.arr === toCode) ||
            (r.dep === toCode && r.arr === fromCode)
        );

        let routeColor = currentColor;
        if (currentPrefix === "ALL" && route) {
          const fltnum = route.fltnum || '';
          const airline = airlines.find((a) => a.suffix && fltnum.includes(a.suffix) && fltnum.startsWith(a.prefix))
                       || airlines.find((a) => !a.suffix && fltnum.startsWith(a.prefix));
          if (airline) routeColor = airline.color;
        }

        const weight = currentPrefix === "ALL" ? 1 : 2;
        const opacity = currentPrefix === "ALL" ? 0.5 : 1;
        const popupHtml = makePopupHtml(route);

        [-360, 0, 360].forEach((offset) => {
          let lon1 = A.lng + offset;
          let lon2 = B.lng + offset;
          const lat1 = A.lat;
          const lat2 = B.lat;

          const diff = Math.abs(lon2 - lon1);

          if (diff <= 180) {
            makeNormalArc(
              [lat1, lon1],
              [lat2, lon2],
              routeColor,
              weight,
              opacity,
              popupHtml
            );
            return;
          }

          if (lon1 < lon2) {
            lon1 += 360;
          } else {
            lon2 += 360;
          }

          const distance = Math.sqrt((lon2 - lon1) ** 2 + (lat2 - lat1) ** 2);
          const curveAmount = Math.max(6, Math.min(16, distance * 0.08));

          const seamGap = 0.8;

          const seamOuterLon = 180 + offset;
          const seamLeftLon = seamOuterLon - seamGap;
          const seamRightLon = -180 + offset + seamGap;

          let seamLat = interpolateLat(lat1, lon1, lat2, lon2, seamOuterLon);

// spread routes apart (THIS fixes everything)
const spread = Math.min(8, distance * 0.08);

// use route identity to keep it consistent (no flicker)
const hash = (fromCode.charCodeAt(0) + toCode.charCodeAt(0)) % 10;

// distribute around seam
seamLat += (hash - 5) * spread * 0.2;

          const seamLeft = [seamLat, seamLeftLon];
          const seamRight = [seamLat, seamRightLon];

          const leftMidLat = (lat1 + seamLat) / 2;
          const leftMidLon = (lon1 + seamLeftLon) / 2;

          const rightEndLon = lon2 - 360;
          const rightMidLat = (seamLat + lat2) / 2;
          const rightMidLon = (seamRightLon + rightEndLon) / 2;

          const horizontalBend = Math.min(12, distance * 0.12);

          const leftControl = [
            leftMidLat + curveAmount,
            leftMidLon - horizontalBend
          ];

          const rightControl = [
            rightMidLat + curveAmount,
            rightMidLon + horizontalBend
          ];

          makeBezierSegment(
            [lat1, lon1],
            leftControl,
            seamLeft,
            routeColor,
            weight,
            opacity,
            popupHtml
          );

          makeBezierSegment(
            seamRight,
            rightControl,
            [lat2, rightEndLon],
            routeColor,
            weight,
            opacity,
            popupHtml
          );
        });
      }

      function highlightAirport(code) {
        if (!airportData[code] || !markers[code]) return;

        clearRoutes();
        const connectedSet = connections[code] || new Set();

        Object.entries(markers).forEach(([otherCode, markerCopies]) => {
          markerCopies.forEach((marker) => {
            if (otherCode === code) {
              marker.setStyle({ fillOpacity: 1, opacity: 1, radius: 10 });
              marker.bringToFront();
            } else if (connectedSet.has(otherCode)) {
              marker.setStyle({ fillOpacity: 0.9, opacity: 1, radius: 8 });
            } else {
              marker.setStyle({ fillOpacity: 0.2, opacity: 0.3, radius: 6 });
            }
          });
        });

        connectedSet.forEach((dest) => drawArc(code, dest));

        const ap = airportData[code];
        map.flyTo([ap.lat, ap.lng], 4, { duration: 0.7 });

        if (markers[code][1]) {
          markers[code][1].openPopup();
        } else if (markers[code][0]) {
          markers[code][0].openPopup();
        }
      }

      function displayRoutesForAirline(prefix, isFltnum = false) {
        if (isFltnum) {
          currentFltnum = prefix;
          currentPrefix = "";
        } else {
          currentPrefix = prefix;
          currentFltnum = "";
        }

        clearRoutes();
        clearMarkers();
        connections = {};

        if (!currentPrefix && !currentFltnum) {
          routeInfo.textContent = "Select an airline to view routes.";
          return;
        }

        if (currentFltnum) {
          currentRoutes = allRoutes.filter((route) => route.fltnum === currentFltnum);
        } else {
          currentRoutes = allRoutes.filter((route) => {
            if (currentPrefix === "ALL") return true;
            const fltnum = route.fltnum || '';
            const match = airlines.find((a) => a.suffix && fltnum.includes(a.suffix) && fltnum.startsWith(a.prefix))
                       || airlines.find((a) => !a.suffix && fltnum.startsWith(a.prefix));
            if (!match) return false;
            const matchId = match.suffix ? `${match.prefix}_${match.suffix}` : match.prefix;
            return matchId === currentPrefix;
          });
        }

        if (currentRegion !== "ALL") {
          currentRoutes = currentRoutes.filter((route) => {
            const depAp = airportData[route.dep];
            const arrAp = airportData[route.arr];
            const depRegion = depAp ? depAp.continent : "OTHER";
            const arrRegion = arrAp ? arrAp.continent : "OTHER";
            return depRegion === currentRegion || arrRegion === currentRegion;
          });
        }

        const neededICAOs = new Set();
        currentRoutes.forEach((route) => {
          neededICAOs.add(route.dep);
          neededICAOs.add(route.arr);
        });

        const routeAirports = {};
        neededICAOs.forEach((icao) => {
          if (airportData[icao]) {
            routeAirports[icao] = airportData[icao];
            connections[icao] = new Set();
          }
        });

        currentRoutes.forEach((route) => {
          if (routeAirports[route.dep] && routeAirports[route.arr]) {
            connections[route.dep].add(route.arr);
            connections[route.arr].add(route.dep);
          }
        });

        Object.entries(routeAirports).forEach(([code, airport]) => {
          const airportRoutes = currentRoutes.filter(
            (r) => r.dep === code || r.arr === code
          );

          const aircraftSet = new Set();
          airportRoutes.forEach((route) => {
            const otherIcao = route.dep === code ? route.arr : route.dep;
            route.aircraft.forEach((aircraft) => {
              aircraftSet.add(
                `${aircraft.liveryname} ${aircraft.name} - <strong>${otherIcao}</strong>`
              );
            });
          });

          const aircraftList =
            aircraftSet.size > 0
              ? "<ul>" +
                Array.from(aircraftSet)
                  .map((a) => `<li>${a}</li>`)
                  .join("") +
                "</ul>"
              : "No aircraft";

          const markerCopies = [];

          [-360, 0, 360].forEach((offset) => {
            const marker = L.circleMarker([airport.lat, airport.lng + offset], {
              radius: currentPrefix === "ALL" ? 6 : 8,
              fillColor: currentColor,
              color: "#ffffff",
              weight: currentPrefix === "ALL" ? 1 : 2,
              fillOpacity: 0.9,
            }).addTo(map);

            marker.bindPopup(
              `<strong>${airport.name}</strong><br>${airport.icao}<br><strong>Aircraft:</strong><br>${aircraftList}`
            );

            marker.on("click", () => highlightAirport(code));
            markerCopies.push(marker);
          });

          markers[code] = markerCopies;
        });

        routeInfo.textContent = `${currentRoutes.length} route${currentRoutes.length === 1 ? '' : 's'}, ${Object.keys(routeAirports).length} airport${Object.keys(routeAirports).length === 1 ? '' : 's'}`;

        if (showLinesToggle.checked) {
          const drawnPairs = new Set();

          currentRoutes.forEach((route) => {
            const pair = [route.dep, route.arr].sort().join("-");
            if (!drawnPairs.has(pair)) {
              drawArc(route.dep, route.arr);
              drawnPairs.add(pair);
            }
          });
        }

        if (Object.keys(routeAirports).length > 0) {
          const bounds = Object.values(routeAirports).map((a) => [a.lat, a.lng]);
          map.fitBounds(bounds, { padding: [40, 40], maxZoom: 3 });
        }
      }

      airlineSelect.addEventListener("change", (e) => {
        currentColor = e.target.selectedOptions[0]?.dataset.color || "#ff0000";
        displayRoutesForAirline(e.target.value);
        window.history.replaceState({}, '', window.location.pathname);
      });

      regionSelect.addEventListener("change", (e) => {
        currentRegion = e.target.value;
        displayRoutesForAirline(currentFltnum || currentPrefix, !!currentFltnum);
      });

      showLinesToggle.addEventListener("change", () => {
        displayRoutesForAirline(currentFltnum || currentPrefix, !!currentFltnum);
      });

      searchInput.addEventListener("input", () => {
        const q = searchInput.value.trim().toLowerCase();

        if (!q) {
          displayRoutesForAirline(currentFltnum || currentPrefix, !!currentFltnum);
          return;
        }

        const found = Object.entries(airportData).find(
          ([code, ap]) =>
            code.toLowerCase().includes(q) ||
            ap.name.toLowerCase().includes(q) ||
            ap.icao.toLowerCase().includes(q)
        );

        if (found && markers[found[0]]) {
          highlightAirport(found[0]);
        }
      });

      airportData = parseCSV(csvText);
      routeInfo.textContent = "Select an airline to view routes.";

      const urlParams = new URLSearchParams(window.location.search);
      const airlineParam = urlParams.get("airline");
      const fltnumParam = urlParams.get("fltnum");

      if (fltnumParam) {
        const matchAirline = airlines.find((a) => a.suffix && fltnumParam.includes(a.suffix) && fltnumParam.startsWith(a.prefix))
                          || airlines.find((a) => !a.suffix && fltnumParam.startsWith(a.prefix));
        if (matchAirline) {
          airlineSelect.value = matchAirline.suffix ? `${matchAirline.prefix}_${matchAirline.suffix}` : matchAirline.prefix;
          currentColor = matchAirline.color || "#ff0000";
        }
        showLinesToggle.checked = true; // Automatically check the show lines toggle for a single route
        displayRoutesForAirline(fltnumParam, true);
      } else if (airlineParam) {
        airlineSelect.value = airlineParam;
        const selectedOption = airlineSelect.querySelector(
          `option[value="${airlineParam}"]`
        );

        if (selectedOption) {
          currentColor = selectedOption.dataset.color || "#ff0000";
          displayRoutesForAirline(airlineParam);
        }
      }
    </script>
  </section>
</Layout>