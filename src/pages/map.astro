  // ---------------------------
  // Convert routes into unique bidirectional pairs
  // ---------------------------
  const routePairs = [];
  const seen = new Set();
  function addPair(a,b) {
    if (!a || !b) return;
    const key = `${a}|${b}`;
    if (!seen.has(key)) {
      seen.add(key);
      routePairs.push([a,b]);
    }
  }

  routes.forEach(r => {
    if (!r) return;
    // r like "A-B"
    if (typeof r === 'string' && r.indexOf('-') !== -1) {
      const [aRaw,bRaw] = r.split('-');
      const a = aRaw.trim();
      const b = bRaw.trim();
      addPair(a,b);
      addPair(b,a);
    }
  });

  // ---------------------------
  // Create markers and click behavior
  // ---------------------------
  const markerMap = {};
  let drawnArcs = [];

  Object.entries(airports).forEach(([code, info]) => {
    // make sure lat/lng are numbers
    const lat = Number(info.lat);
    const lng = Number(info.lng);
    if (isNaN(lat) || isNaN(lng)) return;

    const marker = L.circleMarker([lat, lng], {
      radius: 5,
      fillColor: "#0077cc",
      color: "#ffffff",
      weight: 1,
      opacity: 1,
      fillOpacity: 0.95
    }).addTo(map);

    const link = airportLinks[code] || "#";
    const popupHtml =
      `<div><b>${info.city} – ${info.name} (${code})</b></div>` +
      `<div><a class="popup-link" href="${link}" target="_blank" rel="noopener noreferrer">View Airport Page</a></div>`;

    marker.bindPopup(popupHtml);

    marker.on('click', () => {
      // Clear previously drawn arcs
      drawnArcs.forEach(a => map.removeLayer(a));
      drawnArcs = [];

      // Draw arcs for this airport
      routePairs.forEach(([from, to]) => {
        if (from === code && airports[to]) {
          const fromCoords = [airports[from].lat, airports[from].lng];
          const toCoords   = [airports[to].lat, airports[to].lng];

          try {
            const arc = new L.Polyline.Arc(fromCoords, toCoords, {
              color: '#e11',
              weight: 2,
              opacity: 0.85,
              vertices: 200
            }).addTo(map);
            drawnArcs.push(arc);
          } catch (err) {
            // fallback straight line if arc plugin fails
            const line = L.polyline([fromCoords, toCoords], { color:'#e11', weight:2, opacity:0.8 }).addTo(map);
            drawnArcs.push(line);
          }
        }
      });

      // Open popup so user can click the "View Airport Page" link
      marker.openPopup();
    });

    markerMap[code] = marker;
  });

  // Fit to bounds to show all markers on load (limited maxZoom)
  (function fitToAll() {
    const latlngs = Object.values(airports).map(a => [a.lat, a.lng]).filter(p => !isNaN(p[0]) && !isNaN(p[1]));
    if (latlngs.length) {
      try { map.fitBounds(latlngs, { padding: [40,40], maxZoom: 3 }); }
      catch(e){ /* ignore */ }
    }
  })();

  // Optional: expose functions for debugging in console
  window._map_data = { airports, routes, routePairs, markerMap };

  </script>
