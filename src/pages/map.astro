---
import Layout from '../layouts/Layout.astro';
import { getRoutes } from '../data/route';
import airlinesData from '../assets/airlines.json';
import csvText from '../assets/airport_database_processed.csv?raw';

const airlines = airlinesData.airlines;
let allRoutes = [];

try {
  allRoutes = await getRoutes();
} catch (error) {
  console.error('Failed to load routes:', error);
  // Fallback to empty array - map will show message to select airline
}
---

<Layout>
  <h1 class="text-3xl font-bold text-center">Interactive Route Map</h1>
  <p class="mt-2 text-center">
    Take a look at the routes you could fly!
  </p>

  <!-- Controls -->
  <div class="flex justify-center items-center gap-4 mt-4">
    <select
      id="airlineSelect"
      class="border border-gray-300 px-4 py-2 rounded shadow-sm"
    >
      <option value="">Select Airline...</option>
      {airlines.map(airline => (
        <option value={airline.prefix} data-color={airline.color}>{airline.name}</option>
      ))}
    </select>
    
    <input
      id="airportSearch"
      type="text"
      placeholder="Search airport..."
      class="border border-gray-300 px-4 py-2 rounded w-60 shadow-sm"
    />
  </div>
  
  <div id="routeInfo" class="text-center mt-2 text-sm text-gray-600"></div>

  <style>
    #map {
      height: 70vh;
      width: 100%;
      margin-top: 1rem;
    }

    .leaflet-popup-content {
      font-size: 14px;
    }

    .leaflet-popup-content strong {
      font-weight: bold;
    }
    .aircraft-icon {
      background: none;
      border: none;
      font-size: 14px;
      text-align: center;
    }
  </style>

  <div id="map"></div>

  <!-- Leaflet + Arc plugin -->
  <link
    rel="stylesheet"
    href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
  />
  <script
    src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
    client:load
  ></script>
  <script
    src="https://unpkg.com/leaflet-arc/bin/leaflet-arc.min.js"
    client:load
  ></script>

  <script client:load define:vars={{ allRoutes, csvText }}>
    const map = L.map("map").setView([20, 10], 2);
    L.tileLayer("https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png", {
      attribution: "&copy; OpenStreetMap & CARTO",
      subdomains: "abcd",
    }).addTo(map);

    let currentColor = "#ff0000";
    let airportData = {};
    let currentRoutes = [];
    let connections = {};
    let markers = {};
    let drawn = [];

    const airlineSelect = document.getElementById('airlineSelect');
    const routeInfo = document.getElementById('routeInfo');
    const searchInput = document.getElementById('airportSearch');

    function parseCSV(csvText) {
      const airports = {};
      const lines = csvText.split('\n');
      for (let i = 1; i < lines.length; i++) {
        const parts = lines[i].split(',');
        if (parts.length >= 5) {
          const icao = parts[0].trim();
          const name = parts[2] ? parts[2].replace(/"/g, '') : icao;
          const lat = parseFloat(parts[3]);
          const lng = parseFloat(parts[4]);
          if (icao && !isNaN(lat) && !isNaN(lng)) {
            airports[icao] = { name, icao, lat, lng };
          }
        }
      }
      return airports;
    }

    function clearRoutes() {
      drawn.forEach(l => map.removeLayer(l));
      drawn = [];
    }

    function drawArc(fromCode, toCode) {
      const A = airportData[fromCode];
      const B = airportData[toCode];
      if (!A || !B) return;

      const route = currentRoutes.find(r => 
        (r.dep === fromCode && r.arr === toCode) || 
        (r.dep === toCode && r.arr === fromCode)
      );

      let arc;
      try {
        arc = new L.Polyline.Arc([A.lat, A.lng], [B.lat, B.lng], {
          color: currentColor,
          weight: 2,
          opacity: 1,
          vertices: 200,
        });
      } catch (e) {
        arc = L.polyline([[A.lat, A.lng], [B.lat, B.lng]], {
          color: currentColor, weight: 2, opacity: 1
        });
      }

      if (route) {
        const aircraftList = route.aircraft.length > 0 ? 
          '<ul>' + route.aircraft.map(a => `<li>${a.liveryname} ${a.name}</li>`).join('') + '</ul>' : 'No aircraft assigned';
        arc.bindPopup(`<strong>${route.fltnum}</strong><br>${route.dep} → ${route.arr}<br><strong>Aircraft:</strong><br>${aircraftList}`);
      }
      
      arc.addTo(map);
      drawn.push(arc);
    }

    function highlightAirport(code) {
      if (!airportData[code]) return;

      clearRoutes();
      const connectedSet = connections[code] || new Set();

      Object.entries(markers).forEach(([otherCode, marker]) => {
        if (otherCode === code) {
          marker.setStyle({ fillOpacity: 1, opacity: 1, radius: 7 });
          marker.bringToFront();
        } else if (connectedSet.has(otherCode)) {
          marker.setStyle({ fillOpacity: 0.9, opacity: 1, radius: 6 });
        } else {
          marker.setStyle({ fillOpacity: 0.2, opacity: 0.3, radius: 5 });
        }
      });

      connectedSet.forEach(dest => drawArc(code, dest));
      const ap = airportData[code];
      map.flyTo([ap.lat, ap.lng], 4, { duration: 0.7 });
      markers[code].openPopup();
    }

    function displayRoutesForAirline(prefix) {
      clearRoutes();
      Object.values(markers).forEach(m => map.removeLayer(m));
      markers = {};
      connections = {};

      if (!prefix) return;

      currentRoutes = allRoutes.filter(route => route.fltnum.startsWith(prefix));
      const neededICAOs = new Set();
      currentRoutes.forEach(route => {
        neededICAOs.add(route.dep);
        neededICAOs.add(route.arr);
      });

      const routeAirports = {};
      neededICAOs.forEach(icao => {
        if (airportData[icao]) {
          routeAirports[icao] = airportData[icao];
          connections[icao] = new Set();
        }
      });

      currentRoutes.forEach(route => {
        if (routeAirports[route.dep] && routeAirports[route.arr]) {
          connections[route.dep].add(route.arr);
          connections[route.arr].add(route.dep);
        }
      });

      Object.entries(routeAirports).forEach(([code, airport]) => {
        const marker = L.circleMarker([airport.lat, airport.lng], {
          radius: 6,
          fillColor: currentColor,
          color: "#ffffff",
          weight: 2,
          fillOpacity: 0.9,
        }).addTo(map);

        const airportRoutes = currentRoutes.filter(r => r.dep === code || r.arr === code);
        const aircraftSet = new Set();
        airportRoutes.forEach(route => {
          route.aircraft.forEach(aircraft => aircraftSet.add(`${aircraft.liveryname} ${aircraft.name}`));
        });
        const aircraftList = aircraftSet.size > 0 ? 
          '<ul>' + Array.from(aircraftSet).map(a => `<li>${a}</li>`).join('') + '</ul>' : 'No aircraft';
        
        marker.bindPopup(`<strong>${airport.name}</strong><br>${airport.icao}<br><strong>Aircraft:</strong><br>${aircraftList}`);
        markers[code] = marker;
        marker.on("click", () => highlightAirport(code));
      });

      routeInfo.textContent = `${currentRoutes.length} routes, ${Object.keys(routeAirports).length} airports`;
      
      if (Object.keys(routeAirports).length > 0) {
        const bounds = Object.values(routeAirports).map(a => [a.lat, a.lng]);
        map.fitBounds(bounds, { padding: [40, 40], maxZoom: 3 });
      }
    }

    airlineSelect.addEventListener('change', (e) => {
      currentColor = e.target.selectedOptions[0]?.dataset.color || '#ff0000';
      displayRoutesForAirline(e.target.value);
    });

    searchInput.addEventListener('input', () => {
      const q = searchInput.value.trim().toLowerCase();
      
      if (!q) {
        clearRoutes();
        Object.values(markers).forEach(m => 
          m.setStyle({ fillOpacity: 0.9, opacity: 1, radius: 6 })
        );
        return;
      }

      const found = Object.entries(airportData).find(([code, ap]) => {
        return (
          code.toLowerCase().includes(q) ||
          ap.name.toLowerCase().includes(q) ||
          ap.icao.toLowerCase().includes(q)
        );
      });

      if (found && markers[found[0]]) {
        highlightAirport(found[0]);
      }
    });

    // Initialize
    airportData = parseCSV(csvText);
    routeInfo.textContent = 'Select an airline to view routes.';
  </script>
</Layout>