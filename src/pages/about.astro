---
import Layout from '../layouts/Layout.astro';
---

<Layout>
<section class="px-6 py-8 min-h-screen">
 <div class="mb-8">
      <div class="flex justify-between items-start gap-4 mb-3">
        <h1 class="text-5xl font-bold text-[#8B1538]">About Us</h1>
        <p class="text-sm text-gray-500 pt-2">
          <a href="/" class="text-[#8B1538] font-semibold hover:underline">Home</a> / About Us
        </p>
      </div>

      <p class="max-w-3xl text-lg text-gray-600 leading-relaxed">
       Qatari Virtual is a welcoming community of aviation enthusiasts united by a passion for flying. We focus on creating engaging events, building meaningful connections, and providing a supportive environment for pilots of all experience levels.
      </p>
    </div>

</Layout>