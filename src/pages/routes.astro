---
import Layout from '../layouts/Layout.astro';
import { fetchApiData } from '../utils/api.ts';
import airlinesData from '../assets/airlines.json';

interface Route {
  id: number;
  fltnum: string;
  dep: string;
  arr: string;
  duration: number;
  airline_id?: number;
  aircraft?: { name: string; liveryname: string }[];
}

let routes: Route[] = [];
let error: string | null = null;

try {
  const data = await fetchApiData('routes');
  if (data.status === 0 && Array.isArray(data.result)) {
    routes = data.result.sort((a, b) => {
      const aQR = a.fltnum?.startsWith('QR') ? 0 : 1;
      const bQR = b.fltnum?.startsWith('QR') ? 0 : 1;
      if (aQR !== bQR) return aQR - bQR;
      return (a.fltnum || '').localeCompare(b.fltnum || '');
    });
  } else {
    error = 'Failed to load route data.';
  }
} catch (e) {
  error = 'Route data unavailable right now.';
}

const airlines = airlinesData.airlines;
const totalRoutes = routes.length;
---

<Layout title="Route Database">
<section class="px-6 py-8 min-h-screen">
  <div class="max-w-7xl mx-auto">
    <div class="flex justify-between items-start gap-4 mb-3">
      <h1 class="text-3xl sm:text-5xl font-bold text-[#8B1538]">Route Database</h1>
      <p class="text-sm text-gray-500 pt-2 hidden sm:inline">
        <a href="/" class="text-[#8B1538] font-semibold hover:underline">Home</a> / Route Database
      </p>
    </div>
    <p class="max-w-3xl text-base sm:text-lg text-gray-600 leading-relaxed mb-3">
      Explore our complete route network. Search and filter by airline, departure, or arrival.
    </p>
    <a href="/map" class="inline-flex items-center gap-1 text-sm text-[#8B1538] font-semibold hover:underline mb-5">
      View Route Map &rarr;
    </a>

    {error && (<div class="bg-red-50 border border-red-200 text-red-700 rounded-xl px-5 py-3 mb-6 text-sm">{error}</div>)}

    <div class="flex flex-wrap items-center gap-2.5 mb-5">
      <select id="filter-airline" class="filter-input w-[180px]">
        <option value="">All Airlines</option>
        {airlines.map(a => <option value={a.suffix ? `${a.prefix}_${a.suffix}` : a.prefix}>{a.name}</option>)}
      </select>
      <input id="filter-dep" type="text" placeholder="Departure" class="filter-input w-[110px]" />
      <input id="filter-arr" type="text" placeholder="Arrival" class="filter-input w-[110px]" />
      <button id="filter-btn" class="bg-[#8B1538] text-white px-4 py-2 rounded-xl text-sm font-semibold hover:bg-[#6e0038] transition">Search</button>
      <span class="text-sm text-gray-500 ml-auto hidden sm:inline" id="route-count">{totalRoutes.toLocaleString()} routes</span>
    </div>

    <!-- desktop table -->
    <div class="hidden sm:block overflow-hidden rounded-2xl border border-[#ead9df] shadow-sm">
      <div class="overflow-auto" style="max-height: 70vh">
        <table class="w-full text-sm text-left" id="route-table">
          <thead class="sticky top-0 z-10 text-white" style="background: linear-gradient(135deg, #6e0038, #8B1538)">
            <tr>
              <th class="py-3 px-4 font-bold">Flt Num</th>
              <th class="py-3 px-4 font-bold">Dep</th>
              <th class="py-3 px-4 font-bold">Arr</th>
              <th class="py-3 px-4 font-bold">Aircraft &amp; Livery</th>
              <th class="py-3 px-4 font-bold cursor-pointer select-none" data-sort="duration">Duration <span class="sort-arrow ml-1">&#9650;</span></th>
            </tr>
          </thead>
          <tbody>
            {routes.map((route, i) => (
              <tr
                class={`route-row border-t border-[#ead9df] hover:bg-[#fcfafb] transition ${i % 2 === 0 ? 'bg-white' : 'bg-[#fdfbfc]'}`}
                data-fltnum={route.fltnum || ''}
                data-dep={route.dep || ''}
                data-arr={route.arr || ''}
                data-airline={(() => {
                  const match = airlines.find(a => a.suffix && (route.fltnum || '').includes(a.suffix) && (route.fltnum || '').startsWith(a.prefix))
                             || airlines.find(a => !a.suffix && (route.fltnum || '').startsWith(a.prefix));
                  return match ? (match.suffix ? `${match.prefix}_${match.suffix}` : match.prefix) : '';
                })()}
                data-duration={route.duration || 0}
              >
                <td class="py-2.5 px-4 font-medium text-gray-800">
                  <div class="flex items-center gap-2">
                    {route.fltnum || '\u2014'}
                    <a href={`/map?fltnum=${route.fltnum}`} class="text-gray-400 hover:text-[#8B1538] transition" title="View specific route on map">
                      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/></svg>
                    </a>
                  </div>
                </td>
                <td class="py-2.5 px-4 font-medium text-gray-700">{route.dep || '\u2014'}</td>
                <td class="py-2.5 px-4 font-medium text-gray-700">{route.arr || '\u2014'}</td>
                <td class="py-2.5 px-4">
                  <div class="flex flex-wrap items-center gap-1 ac-group">
                    {route.aircraft?.slice(0, 2).map((ac) => (
                      ac && <span class="ac-tag text-xs font-medium px-2 py-0.5 rounded-full border border-[#ead9df]" style="background:#f8f1f3;color:#8B1538">{ac.name} ({ac.liveryname})</span>
                    ))}
                    {(route.aircraft?.length || 0) > 2 && (
                      <>
                        {route.aircraft?.slice(2).map((ac) => (
                          ac && <span class="ac-tag ac-extra text-xs font-medium px-2 py-0.5 rounded-full border border-[#ead9df] hidden" style="background:#f8f1f3;color:#8B1538">{ac.name} ({ac.liveryname})</span>
                        ))}
                        <button class="ac-expand text-xs font-semibold px-2 py-0.5 rounded-full border transition" style="color:#8B1538;border-color:#ead9df;background:white">+{route.aircraft.length - 2}</button>
                      </>
                    )}
                  </div>
                </td>
                <td class="py-2.5 px-4 text-gray-500">{route.duration ? `${Math.floor(route.duration / 3600)}h ${Math.floor((route.duration % 3600) / 60)}m` : '\u2014'}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- mobile cards -->
    <div class="sm:hidden space-y-3" id="mobile-list">
      {routes.map((route) => (
        <div
          class="route-card bg-white rounded-2xl border border-[#ead9df] p-4 shadow-sm"
          data-fltnum={route.fltnum || ''}
          data-dep={route.dep || ''}
          data-arr={route.arr || ''}
          data-airline={(() => {
            const match = airlines.find(a => a.suffix && (route.fltnum || '').includes(a.suffix) && (route.fltnum || '').startsWith(a.prefix))
                       || airlines.find(a => !a.suffix && (route.fltnum || '').startsWith(a.prefix));
            return match ? (match.suffix ? `${match.prefix}_${match.suffix}` : match.prefix) : '';
          })()}
          data-duration={route.duration || 0}
        >
          <div class="flex items-center justify-between mb-2">
            <div class="flex items-center gap-2">
              <span class="font-bold text-lg" style="color:#8B1538">{route.fltnum || '\u2014'}</span>
              <a href={`/map?fltnum=${route.fltnum}`} class="text-gray-400 hover:text-[#8B1538] transition p-0.5" title="View specific route on map">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/></svg>
              </a>
            </div>
            <span class="text-xs text-gray-400">{route.duration ? `${Math.floor(route.duration / 3600)}h ${Math.floor((route.duration % 3600) / 60)}m` : '\u2014'}</span>
          </div>
          <div class="flex items-center gap-3 text-sm mb-2">
            <span class="font-semibold text-gray-800">{route.dep || '\u2014'}</span>
            <svg class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3"/></svg>
            <span class="font-semibold text-gray-800">{route.arr || '\u2014'}</span>
          </div>
          <div class="flex flex-wrap items-center gap-1 ac-group mb-2" data-route-id={route.id}>
            {route.aircraft?.slice(0, 2).map((ac) => (
              ac && <span class="ac-tag text-xs font-medium px-2 py-0.5 rounded-full" style="background:#f8f1f3;color:#8B1538">{ac.name} ({ac.liveryname})</span>
            ))}
            {(route.aircraft?.length || 0) > 2 && (
              <>
                {route.aircraft?.slice(2).map((ac) => (
                  ac && <span class="ac-tag ac-extra text-xs font-medium px-2 py-0.5 rounded-full hidden" style="background:#f8f1f3;color:#8B1538">{ac.name} ({ac.liveryname})</span>
                ))}
                <button class="ac-expand text-xs font-semibold px-2 py-0.5 rounded-full border transition" style="color:#8B1538;border-color:#ead9df;background:white">+{route.aircraft.length - 2}</button>
              </>
            )}
          </div>
        </div>
      ))}
    </div>

    <div class="text-center text-sm text-gray-400 mt-3" id="no-results" style="display:none">No routes match your filters.</div>
  </div>
</section>
</Layout>

<script>
  const filterAirline = document.getElementById('filter-airline') as HTMLSelectElement;
  const filterFltnum = document.getElementById('filter-fltnum') as HTMLInputElement;
  const filterDep = document.getElementById('filter-dep') as HTMLInputElement;
  const filterArr = document.getElementById('filter-arr') as HTMLInputElement;
  const routeCount = document.getElementById('route-count');
  const noResults = document.getElementById('no-results');
  const tableRows = document.querySelectorAll('.route-row');
  const cards = document.querySelectorAll('.route-card');
  const table = document.getElementById('route-table');

  function filterRows() {
    const qAirline = filterAirline?.value || '';
    const qFlt = (filterFltnum?.value || '').toLowerCase();
    const qDep = (filterDep?.value || '').toLowerCase();
    const qArr = (filterArr?.value || '').toLowerCase();

    const items = tableRows.length ? tableRows : cards;
    let visible = 0;

    items.forEach(item => {
      const airline = (item.dataset.airline || '');
      const fltnum = (item.dataset.fltnum || '').toLowerCase();
      const depVal = (item.dataset.dep || '').toLowerCase();
      const arrVal = (item.dataset.arr || '').toLowerCase();

      const ok = (!qAirline || airline === qAirline)
        && (!qFlt || fltnum.includes(qFlt))
        && (!qDep || depVal.includes(qDep))
        && (!qArr || arrVal.includes(qArr));

      (item as HTMLElement).style.display = ok ? '' : 'none';
      if (ok) visible++;
    });

    if (routeCount) routeCount.textContent = `${visible.toLocaleString()} of ${items.length.toLocaleString()} routes`;
    if (noResults) noResults.style.display = visible === 0 ? '' : 'none';

    // sync URL
    const params = new URLSearchParams();
    if (qAirline) params.set('airline', qAirline);
    if (qFlt) params.set('flt', qFlt);
    if (qDep) params.set('dep', qDep);
    if (qArr) params.set('arr', qArr);
    const newUrl = params.toString() ? `${window.location.pathname}?${params.toString()}` : window.location.pathname;
    window.history.replaceState({}, '', newUrl);
  }

  // load filters from URL on page load
  const params = new URLSearchParams(window.location.search);
  if (params.get('airline') && filterAirline) filterAirline.value = params.get('airline')!;
  if (params.get('flt') && filterFltnum) filterFltnum.value = params.get('flt')!;
  if (params.get('dep') && filterDep) filterDep.value = params.get('dep')!;
  if (params.get('arr') && filterArr) filterArr.value = params.get('arr')!;
  if (params.toString()) filterRows();

  const filterBtn = document.getElementById('filter-btn');
  filterBtn?.addEventListener('click', filterRows);

  // Allow pressing "Enter" inside the text boxes to trigger the search
  const handleEnter = (e: KeyboardEvent) => { if (e.key === 'Enter') filterRows(); };
  filterDep?.addEventListener('keypress', handleEnter);
  filterArr?.addEventListener('keypress', handleEnter);

  // sort
  let currentSort = { key: null as string | null, asc: true };

  table?.querySelectorAll('[data-sort]').forEach(th => {
    th.addEventListener('click', () => {
      const key = th.dataset.sort!;
      if (currentSort.key === key) { currentSort.asc = !currentSort.asc; }
      else { currentSort.key = key; currentSort.asc = true; }

      const tbody = table.querySelector('tbody');
      if (!tbody) return;
      const arr = Array.from(tbody.querySelectorAll('.route-row'));

      arr.sort((a, b) => {
        const aVal = (a.dataset[key as string] || '').toLowerCase();
        const bVal = (b.dataset[key as string] || '').toLowerCase();
        if (key === 'duration') {
          return currentSort.asc ? Number(aVal) - Number(bVal) : Number(bVal) - Number(aVal);
        }
        return currentSort.asc ? aVal.localeCompare(bVal) : bVal.localeCompare(aVal);
      });

      arr.forEach(r => tbody.appendChild(r));
    });
  });

  // expand aircraft
  document.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.ac-expand');
    if (!btn) return;
    const group = btn.closest('.ac-group');
    if (!group) return;
    const extras = group.querySelectorAll('.ac-extra');
    const isExpanded = btn.dataset.open === '1';
    if (isExpanded) {
      extras.forEach(el => (el as HTMLElement).classList.add('hidden'));
      btn.textContent = `+${extras.length}`;
      btn.dataset.open = '0';
    } else {
      extras.forEach(el => (el as HTMLElement).classList.remove('hidden'));
      btn.textContent = '\u2013 less';
      btn.dataset.open = '1';
    }
  });
</script>

<style>
  .filter-input {
    border: 1px solid #ead9df;
    border-radius: 12px;
    padding: 0.55rem 0.85rem;
    font-size: 0.875rem;
    background: white;
    outline: none;
    transition: border-color 0.2s;
  }
  .filter-input:focus {
    border-color: #8B1538;
    box-shadow: 0 0 0 2px rgba(139,21,56,0.1);
  }
  .ac-expand:hover {
    background: #f8f1f3 !important;
  }
</style>
