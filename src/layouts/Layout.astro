---
import '../styles/global.css';
import MdiIcon from '@mdi/react';
import { mdiArrowTopRightThick, mdiMenu, mdiClose } from '@mdi/js';
import Footer from '../components/Footer.astro';

const { title = 'Qatari Virtual Landing' } = Astro.props;
const Icon = MdiIcon && 'default' in MdiIcon ? MdiIcon.default : MdiIcon;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>

    <style>
      .header-shell {
        position: sticky;
        top: 0;
        z-index: 1200;
        background: rgba(255, 255, 255, 0.32);
        color: #6e0038;
        border-bottom: 1px solid transparent;
        box-shadow: none;
        backdrop-filter: blur(6px);
        transition: background 0.4s ease, box-shadow 0.4s ease, border-color 0.4s ease, backdrop-filter 0.4s ease;
      }


      .header-shell.is-scrolled {
        background: linear-gradient(120deg, #4a0c2b, #6e0038);
        color: white;
        border-bottom: 1px solid rgba(255, 255, 255, 0.12);
        box-shadow: 0 16px 45px rgba(24, 8, 16, 0.22);
        backdrop-filter: blur(10px);
      }

      .header-shell.is-scrolled .nav-link,
      .header-shell.is-scrolled .brand-tagline {
        color: white;
      }

      .header-shell.is-scrolled .dropdown-arrow {
        color: white;
      }

      .brand-wrap {
        display: flex;
        align-items: center;
        gap: 1rem;
      }

      .brand-logo {
        height: 46px;
        width: auto;
        display: block;
      }

      .brand-logo-stack {
        position: relative;
        height: 46px;
        width: auto;
        display: inline-flex;
        align-items: center;
      }

      .brand-logo-stack img {
        height: 46px;
        width: auto;
        display: block;
        transition: opacity 0.4s ease;
      }

      .brand-logo-stack .logo-light {
        opacity: 1;
      }

      .brand-logo-stack .logo-dark {
        position: absolute;
        left: 0;
        opacity: 0;
      }

      .header-shell.is-scrolled .brand-logo-stack .logo-light {
        opacity: 0;
      }

      .header-shell.is-scrolled .brand-logo-stack .logo-dark {
        opacity: 1;
      }

      .brand-tagline {
        color: #6e0038;
        font-size: 1.15rem;
        font-weight: 400;
        letter-spacing: -0.02em;
        white-space: nowrap;
        opacity: 0.9;
      }

      .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }

      .main-nav {
        display: flex;
        align-items: center;
        gap: 1.25rem;
        margin-left: auto;
      }

      .nav-toggle {
        display: none;
        align-items: center;
        justify-content: center;
        width: 44px;
        height: 44px;
        border-radius: 999px;
        border: none;
        background: transparent;
        color: #6e0038;
        cursor: pointer;
        transition: background 0.2s ease, transform 0.2s ease;
      }

      .nav-toggle:hover {
        background: transparent;
        transform: translateY(-1px);
      }

      .nav-toggle-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: opacity 0.2s ease, transform 0.2s ease;
      }

      .nav-toggle .icon-close {
        position: absolute;
        opacity: 0;
        transform: scale(0.95);
      }

      .nav-toggle[aria-expanded="true"] .icon-open {
        opacity: 0;
        transform: scale(0.95);
      }

      .nav-toggle[aria-expanded="true"] .icon-close {
        opacity: 1;
        transform: scale(1);
      }

      .header-shell.is-scrolled .nav-toggle {
        color: white;
      }

      .nav-item {
        position: relative;
        list-style: none;
      }

      .nav-link {
        position: relative;
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        font-weight: 700;
        font-size: 1rem;
        color: #6e0038;
        text-decoration: none;
        padding: 0.35rem 0;
        transition: opacity 0.2s ease, color 0.3s ease;
      }

      .nav-link:hover {
        opacity: 0.85;
      }

      .dropdown-arrow {
        width: 0.9rem;
        height: 0.9rem;
        transition: transform 0.22s ease;
      }

      .nav-cta {
        background: #6e0038;
        border: none;
        color: white;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.3rem;
        line-height: 1.1;
        padding: 0.45rem 0.9rem;
        min-height: 36px;
        border-radius: 999px;
        font-weight: 700;
        letter-spacing: 0.01em;
        transition: background 0.3s ease, color 0.3s ease, border-color 0.3s ease, transform 0.2s ease;
      }

      .nav-cta:hover {
        background: #7d0b44;
        transform: translateY(-1px);
      }

      .header-shell.is-scrolled .nav-cta {
        background: white;
        color: #6e0038;
      }

      .header-shell.is-scrolled .nav-cta:hover {
        background: #f8f1f3;
      }

      .nav-cta-icon {
        display: inline-flex;
        align-items: center;
        transition: transform 0.2s ease;
      }

      .nav-cta:hover .nav-cta-icon {
        transform: translateX(3px);
      }

      .dropdown-menu {
        position: absolute;
        top: calc(100% + 12px);
        left: 0;
        min-width: 220px;
        background: white;
        border: 1px solid rgba(110, 0, 56, 0.08);
        border-radius: 14px;
        box-shadow: 0 18px 45px rgba(0, 0, 0, 0.12);
        padding: 0.55rem;
        opacity: 0;
        visibility: hidden;
        transform: translateY(-10px);
        transition: opacity 0.22s ease, transform 0.22s ease, visibility 0.22s ease;
        z-index: 1000;
      }

      .dropdown-menu a {
        display: block;
        padding: 0.8rem 0.95rem;
        border-radius: 10px;
        color: #2f2f2f;
        font-weight: 600;
        text-decoration: none;
        transition: background 0.2s ease, color 0.2s ease, transform 0.2s ease;
      }

      .dropdown-menu a:hover {
        background: #f8f1f4;
        color: #6e0038;
        transform: translateX(2px);
      }

      .nav-item:hover .dropdown-menu {
        opacity: 1;
        visibility: visible;
        transform: translateY(0);
      }

      .nav-item:hover .dropdown-arrow {
        transform: rotate(180deg);
      }

      @media (max-width: 1100px) {
        .brand-tagline {
          font-size: 1rem;
        }

        .main-nav {
          gap: 0.85rem;
        }

        .nav-link {
          font-size: 0.95rem;
        }

        .brand-logo-stack img {
          height: 42px;
        }
      }

      @media (max-width: 900px) {
        .brand-tagline {
          display: none;
        }

        .main-nav {
          display: none;
          position: absolute;
          top: calc(100% + 10px);
          right: 1.5rem;
          width: min(320px, 90vw);
          flex-direction: column;
          align-items: flex-start;
          gap: 0.25rem;
          padding: 0.75rem;
          background: white;
          border-radius: 16px;
          box-shadow: 0 18px 45px rgba(0, 0, 0, 0.18);
          z-index: 1201;
        }

        .header-shell.is-scrolled .main-nav {
          background: #6e0038;
        }

        .header-shell.is-scrolled .main-nav .nav-link {
          color: white;
        }

        .header-shell.is-scrolled .dropdown-menu a {
          color: #2f2f2f;
        }

        .main-nav.is-open {
          display: flex;
        }

        .nav-item {
          width: 100%;
        }

        .nav-link {
          width: 100%;
          justify-content: space-between;
          padding: 0.6rem 0.85rem;
          border-radius: 12px;
        }

        .nav-link:hover {
          background: #f8f1f4;
          opacity: 1;
        }

        .nav-item.has-dropdown > .nav-link {
          cursor: pointer;
        }

        .nav-item.has-dropdown > .nav-link {
          margin-bottom: 0.25rem;
        }

        .dropdown-menu {
          position: relative;
          opacity: 1;
          visibility: visible;
          transform: none;
          box-shadow: none;
          border: none;
          background: transparent;
          padding: 0.25rem 0 0.5rem 0.5rem;
          max-height: 0;
          overflow: hidden;
          transition: max-height 0.35s ease;
        }

        .nav-item.has-dropdown.is-expanded > .dropdown-menu {
          max-height: 600px;
        }

        .nav-item.has-dropdown > .nav-link .dropdown-arrow {
          transition: transform 0.25s ease;
        }

        .nav-item.has-dropdown.is-expanded > .nav-link .dropdown-arrow {
          transform: rotate(180deg);
        }

        .nav-item.has-dropdown > .dropdown-menu,
        .nav-link + .dropdown-menu {
          display: block;
        }

        .dropdown-menu a {
          padding: 0.5rem 0.6rem;
        }

        .nav-cta {
          width: 100%;
          justify-content: center;
        }

        .nav-toggle {
          display: inline-flex;
          margin-left: auto;
        }

        .dropdown-menu {
          min-width: 190px;
        }

        .nav-cta {
          padding: 0.4rem 0.8rem;
          min-height: 34px;
        }
      }

      @media (max-width: 700px) {
        .header-shell {
          padding-top: 0.65rem;
          padding-bottom: 0.65rem;
        }

        .brand-wrap {
          width: 100%;
          justify-content: flex-start;
        }
      }
    </style>
  </head>

  <body>
    <header class="header-shell px-6 py-3 md:px-8">
      <nav class="flex w-full items-center justify-between" data-nav-root>
        <div class="brand-wrap">
          <a href="/">
            <span class="brand-logo-stack" aria-hidden="true">
              <img src="/images/QRV-Logo2.png" alt="" class="logo-light" />
              <img src="/images/QRV-Logo1.png" alt="" class="logo-dark" />
            </span>
            <span class="sr-only">Qatari Virtual</span>
          </a>
          <span class="brand-tagline">The Home Of Excellence</span>
        </div>

        <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="main-nav" aria-label="Toggle navigation">
          <span class="nav-toggle-icon icon-open" aria-hidden="true">
            <Icon path={mdiMenu} size={1} />
          </span>
          <span class="nav-toggle-icon icon-close" aria-hidden="true">
            <Icon path={mdiClose} size={1} />
          </span>
        </button>

        <ul class="main-nav" id="main-nav">
          <li class="nav-item has-dropdown">
            <a href="#" class="nav-link" data-dropdown-toggle>
              About
              <svg class="dropdown-arrow" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="m6 9 6 6 6-6" />
              </svg>
            </a>
            <div class="dropdown-menu">
              <a href="/about">About Us</a>
              <a href="/staff">Staff</a>
            </div>
          </li>

          <li class="nav-item has-dropdown">
            <a href="#" class="nav-link" data-dropdown-toggle>
              Operations
              <svg class="dropdown-arrow" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="m6 9 6 6 6-6" />
              </svg>
            </a>
            <div class="dropdown-menu">
              <a href="/fleet">Fleet</a>
              <a href="/codeshares">Codeshares</a>
              <a href="/routes">Route Database</a>
              <a href="/map">Route Map</a>
              <a href="/ranks">Ranks</a>
              <a href="/tours">Tours</a>
            </div>
          </li>

          <li class="nav-item">
            <a href="https://crew.qatarivirtual.xyz" target="_blank" rel="noopener noreferrer" class="nav-link">Crew Center</a>
          </li>

          <li class="nav-item">
            <a href="/apply" class="nav-link nav-cta">
              Apply
              <span class="nav-cta-icon" aria-hidden="true">
                <Icon path={mdiArrowTopRightThick} size={1} />
              </span>
            </a>
          </li>
        </ul>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <Footer />

    <script>
      const header = document.querySelector('.header-shell');
      if (header) {
        const updateHeader = () => {
          header.classList.toggle('is-scrolled', window.scrollY > 12);
        };
        updateHeader();
        window.addEventListener('scroll', updateHeader, { passive: true });
      }

      const navRoot = document.querySelector('[data-nav-root]');
      if (navRoot) {
        const toggle = navRoot.querySelector('.nav-toggle');
        const menu = navRoot.querySelector('#main-nav');
        if (toggle && menu) {
          const closeMenu = () => {
            menu.classList.remove('is-open');
            toggle.setAttribute('aria-expanded', 'false');
          };

          toggle.addEventListener('click', () => {
            const isOpen = menu.classList.toggle('is-open');
            toggle.setAttribute('aria-expanded', String(isOpen));
          });

          document.addEventListener('click', (event) => {
            if (!navRoot.contains(event.target)) {
              closeMenu();
            }
          });

          window.addEventListener('resize', () => {
            if (window.innerWidth > 900) {
              closeMenu();
            }
          });
        }
      }

      const dropdowns = document.querySelectorAll('[data-dropdown-toggle]');
      dropdowns.forEach((toggle) => {
        toggle.addEventListener('click', (event) => {
          // Only collapse on mobile (below 900px)
          if (window.innerWidth > 900) return;

          event.preventDefault();
          const parent = toggle.closest('.nav-item');
          if (!parent) return;
          parent.classList.toggle('is-expanded');

          // Close sibling dropdowns
          const siblings = parent.parentElement.querySelectorAll('.nav-item.has-dropdown.is-expanded');
          siblings.forEach((sib) => {
            if (sib !== parent) sib.classList.remove('is-expanded');
          });
        });
      });
    </script>
  </body>
</html>
