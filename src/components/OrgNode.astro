---
import type { StaffMember } from '../data/staff';

interface Props {
  member?: StaffMember;
  title?: string;
  type?: 'boss' | 'exec' | 'manager' | 'staff'; 
}

const { member, title, type = 'manager' } = Astro.props;

// Formatting date
const joinedDate = member ? new Date(member.joined).toLocaleDateString('en-US', {
    month: 'short', year: 'numeric'
}) : '';

// --- COLOR LOGIC ---
let cardBg = '';
let textColor = 'text-white';
let subTextColor = 'text-white/70';

switch (type) {
    case 'boss':
    case 'exec':
        // Burgundy (Maroon)
        cardBg = `background: linear-gradient(135deg, #580e33 0%, #751842 100%);`;
        break;
    case 'manager':
        // Orange
        cardBg = `background: linear-gradient(135deg, #ea580c 0%, #c2410c 100%);`; 
        break;
    case 'staff':
        // Yellow (Gold)
        cardBg = `background: linear-gradient(135deg, #ca8a04 0%, #a16207 100%);`; 
        break;
}

const displayTitle = title || member?.role || 'Vacant';

const widthClass = 'w-64'; 
const heightClass = 'h-20'; 
---

{/* CASE 1: VACANT */}
{!member && (
    <div class={`${widthClass} ${heightClass} flex flex-col items-center justify-center gap-1 opacity-50 border-2 border-dashed border-base-300 rounded-3xl bg-base-100`}>
        <span class="text-[10px] font-bold text-base-content/50 uppercase tracking-widest">{displayTitle}</span>
        <span class="text-[10px] italic text-base-content/40">Vacant</span>
    </div>
)}

{/* CASE 2: OCCUPIED CARD */}
{member && (
    /* 
       WRAPPER 
       - Default z-index is handled by the parent in OrgChart to ensure hierarchy stacking.
       - hover:z-[100] forces this specific card to the very front when interacting.
    */
    <div class={`relative ${widthClass} ${heightClass} transition-all duration-300 hover:z-[100]`}>
        
        <div 
            class="absolute top-0 left-0 w-full rounded-3xl shadow-md hover:shadow-2xl hover:scale-105 transition-all duration-300 overflow-hidden group cursor-pointer"
            style={cardBg}
        >
            
            {/* TOP SECTION */}
            <div class={`${heightClass} flex items-center gap-3 px-4 relative z-10 transition-all`}>
                <div class="avatar">
                    <div class={`rounded-full ring-2 ring-white/30 ring-offset-1 ring-offset-transparent shadow-md w-12`}>
                        <img src={member.avatar_url} alt={member.callsign} />
                    </div>
                </div>
                <div class={`text-left ${textColor} leading-tight min-w-0`}>
                    <div class="text-base font-bold tracking-tight truncate pr-2">{member.name}</div>
                    <div class={`text-[10px] font-bold uppercase tracking-widest ${subTextColor} truncate`}>
                        {displayTitle}
                    </div>
                </div>
            </div>

            {/* EXPANDABLE SECTION */}
            <div class="max-h-0 group-hover:max-h-40 transition-[max-height] duration-500 ease-in-out bg-black/20">
                <div class={`px-5 pb-4 pt-2 ${subTextColor} space-y-3 relative z-10`}>
                    <div class="h-[1px] bg-white/20 w-full"></div>
                    <div class="flex justify-between items-end text-sm">
                        <div class="flex flex-col">
                            <span class="text-[9px] uppercase opacity-70 font-bold">Callsign</span>
                            <span class={`font-mono font-bold text-base ${textColor}`}>{member.callsign}</span>
                        </div>
                        <a href={member.ifc} target="_blank" class={`btn btn-xs btn-circle btn-ghost ${textColor} hover:bg-white/20 tooltip tooltip-left`} data-tip="IFC Profile">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
                        </a>
                    </div>
                    <div class="flex justify-between items-center text-xs">
                         <span class="opacity-70">Joined:</span>
                         <span class={`font-medium ${textColor}`}>{joinedDate}</span>
                    </div>
                </div>
            </div>
            
        </div>
    </div>
)}